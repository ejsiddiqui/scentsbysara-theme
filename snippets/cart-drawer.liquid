{{ 'section-cart.css' | asset_url | stylesheet_tag }}

<cart-drawer
  class="cart-drawer"
  data-currency-code="{{ cart.currency.iso_code }}"
  {% if settings.cart_auto_open %}data-auto-open{% endif %}
>
  <dialog ref="dialog" class="cart-drawer-dialog" aria-modal="true" aria-labelledby="cart-drawer-title">
    <div class="cart-drawer__inner">
      <header class="cart-drawer-header">
        <h2 id="cart-drawer-title" class="font-serif text-h3">YOUR BAG</h2>
        <button type="button" ref="close" class="icon-btn" data-dialog-close aria-label="Close cart">
          {% render 'icon', name: 'close', size: 18 %}
        </button>
      </header>

      <div class="cart-drawer-body" data-cart-drawer-content>
        {%- if cart.item_count > 0 -%}
          <div class="cart-drawer-items">
            {%- for item in cart.items -%}
              <article class="cart-drawer-item" data-line="{{ forloop.index }}">
                <a href="{{ item.url }}" class="cart-drawer-item__media">
                  {%- if item.image != blank -%}
                    {% render 'image',
                      image: item.image,
                      alt: item.product.title,
                      sizes: '120px',
                      widths: '120,180,240',
                      loading: 'lazy',
                      class: 'cart-drawer-item__image'
                    %}
                  {%- endif -%}
                </a>

                <div class="cart-drawer-item__content">
                  <div class="cart-drawer-item__copy">
                    <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                    {%- if item.variant.title != blank and item.variant.title != 'Default Title' -%}
                      <p class="text-micro text-muted">{{ item.variant.title }}</p>
                    {%- endif -%}
                  </div>

                  <div class="cart-drawer-item__actions">
                    <quantity-selector class="quantity-selector cart-quantity" data-line="{{ forloop.index }}">
                      <button type="button" class="qty-btn" data-action="decrease" aria-label="Decrease quantity">-</button>
                      <input type="number" value="{{ item.quantity }}" min="1" aria-label="Quantity for {{ item.product.title | escape }}">
                      <button type="button" class="qty-btn" data-action="increase" aria-label="Increase quantity">+</button>
                    </quantity-selector>

                    <button type="button" class="cart-line-remove" data-cart-remove data-line="{{ forloop.index }}">
                      Remove
                    </button>
                  </div>
                </div>

                <div class="cart-drawer-item__price">
                  {%- if item.original_line_price > item.final_line_price -%}
                    <s class="price-strikethrough">{{ item.original_line_price | money }}</s>
                  {%- endif -%}
                  <span class="price-current">{{ item.final_line_price | money }}</span>
                </div>
              </article>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="cart-empty-state">
            <p class="cart-empty-message text-muted">Your bag is empty.</p>
            <a href="{{ routes.collections_url }}" class="btn-outline">CONTINUE SHOPPING</a>
          </div>
        {%- endif -%}
      </div>

      <footer class="cart-drawer-footer">
        <div class="cart-summary-row flex-between">
          <span>SUBTOTAL</span>
          <span data-cart-subtotal>{{ cart.total_price | money }}</span>
        </div>

        <p class="cart-summary-note text-micro text-muted">Shipping and tax are calculated at checkout.</p>

        <div class="cart-drawer-footer__actions">
          <a href="{{ routes.cart_url }}" class="btn-outline">VIEW BAG</a>
          <form action="{{ routes.cart_url }}" method="post" id="CartDrawerCheckoutForm">
            <button
              type="submit"
              class="btn-solid"
              name="checkout"
              data-cart-checkout-button
              {% if cart.item_count == 0 %}disabled{% endif %}
            >
              CHECKOUT
            </button>
          </form>
        </div>
      </footer>
    </div>
  </dialog>
</cart-drawer>
