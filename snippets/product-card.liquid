{%- liquid
  assign card_product = product | default: card_product
  assign image_ratio = image_ratio | default: settings.card_image_ratio
  assign card_layout = card_layout | default: 'stacked'
  assign show_secondary_image = show_secondary_image
  assign show_swatches = show_swatches
  assign show_quick_add = show_quick_add
  assign show_wishlist = show_wishlist | default: false
  assign current_variant = blank
  assign primary_image = blank
  assign secondary_image = blank
  assign subtitle = subtitle
  assign current_product_url = card_product.url

  if show_secondary_image == blank and show_secondary_image != false
    assign show_secondary_image = settings.card_show_secondary_image
  endif

  if show_swatches == blank and show_swatches != false
    assign show_swatches = settings.card_show_swatches
  endif

  if show_quick_add == blank and show_quick_add != false
    assign show_quick_add = settings.card_show_quick_add
  endif

  if show_secondary_image and secondary_image != blank and secondary_image != primary_image
    assign has_secondary_image = true
  endif

  if card_product != blank
    assign current_variant = variant | default: card_product.selected_or_first_available_variant
    assign primary_image = card_product.featured_image | default: card_product.images.first
    assign secondary_image = card_product.images[1]
    assign has_secondary_image = false

    if show_secondary_image and secondary_image != blank and secondary_image != primary_image
      assign has_secondary_image = true
    endif

    assign subtitle = subtitle | default: card_product.metafields.custom.short_description | default: card_product.type
    if subtitle == blank
      assign subtitle = card_product.vendor
    endif

    if current_variant != blank
      assign current_product_url = card_product.url | append: '?variant=' | append: current_variant.id
    endif
  endif
-%}

{%- if card_product != blank -%}
  {%- capture card_variants_json -%}
    [{%- for v in card_product.variants -%}
      {%- liquid
        assign variant_compare_value = ''
        if v.compare_at_price > v.price
          assign variant_compare_value = v.compare_at_price | money
        endif

        assign variant_image = ''
        assign variant_image_srcset = ''

        if v.featured_image != blank
          assign variant_image = v.featured_image | image_url: width: 800
          capture variant_image_srcset
            for image_width in (1..4)
              assign width_value = '320'
              case image_width
                when 2
                  assign width_value = '480'
                when 3
                  assign width_value = '640'
                when 4
                  assign width_value = '800'
              endcase
              echo v.featured_image | image_url: width: width_value
              echo ' '
              echo width_value
              echo 'w'
              unless forloop.last
                echo ', '
              endunless
            endfor
          endcapture
        endif
      -%}
      {
        "id":{{ v.id }},
        "url":{{ card_product.url | append: '?variant=' | append: v.id | json }},
        "optionNames":{{ card_product.options | json }},
        "options":{{ v.options | json }},
        "price":{{ v.price | money | json }},
        "compareAt":{{ variant_compare_value | json }},
        "image":{{ variant_image | json }},
        "imageSrcset":{{ variant_image_srcset | strip | json }}
      }
      {%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}]
  {%- endcapture -%}
{%- endif -%}

{%- if card_product != blank -%}
  <product-card
    class="product-card product-card--{{ card_layout }}{% if card_product.available == false %} is-sold-out{% endif %}"
    data-product-card
    data-product-card-id="{{ card_product.id }}"
    data-product-url="{{ current_product_url }}"
    data-current-variant-id="{{ current_variant.id }}"
    data-card-layout="{{ card_layout }}"
    data-card-image-ratio="{{ image_ratio }}"
    data-variants='{{ card_variants_json | strip }}'
  >
    <div class="product-card-media product-card__media-shell">
      <a
        class="product-image-wrap product-card__media"
        href="{{ current_product_url }}"
        aria-label="{{ card_product.title | escape }}"
      >
        {%- if primary_image != blank -%}
          {% render 'image',
            class: 'product-card__image product-card__image--primary',
            image: primary_image,
            widths: '320,480,640,800',
            sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 40vw, 78vw'
          %}
        {%- else -%}
          <div class="image product-card__image product-card__image--placeholder" aria-hidden="true"></div>
        {%- endif -%}

        {%- if has_secondary_image -%}
          {% render 'image',
            class: 'product-card__image product-card__image--secondary',
            image: secondary_image,
            widths: '320,480,640,800',
            sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 40vw, 78vw'
          %}
        {%- endif -%}
      </a>

      {%- if show_wishlist -%}
        <button
          class="product-card__wishlist icon-btn"
          type="button"
          aria-label="Add {{ card_product.title | escape }} to wishlist"
          aria-pressed="false"
        >
          {% render 'icon', name: 'wishlist', size: 20 %}
        </button>
      {%- endif -%}

      {%- if show_quick_add and card_product.available -%}
        <button
          class="product-btn-add product-card__quick-add"
          type="button"
          data-product-card-quick-add
          data-product-card-quick-add-url="{% if current_variant != blank %}{{ card_product.url }}?variant={{ current_variant.id }}{% else %}{{ card_product.url }}{% endif %}"
          aria-label="Quick add {{ card_product.title | escape }}"
        >
          +
        </button>
      {%- endif -%}

      {%- unless card_product.available -%}
        <span class="product-card__badge" aria-label="Sold out">Sold out</span>
      {%- endunless -%}
    </div>

    {%- if card_layout == 'shop' -%}
      <div class="product-options product-card__options">
        {%- for option in card_product.options_with_values -%}
          {%- assign opt_down = option.name | downcase -%}
          {%- if opt_down contains 'body' or opt_down contains 'shape' or opt_down contains 'size' -%}
            <select
              class="product-card__option-select"
              data-product-card-option="{{ option.name | downcase }}"
            >
              {%- for value in option.values -%}
                <option
                  value="{{ value | escape }}"
                  {%- if current_variant.options[forloop.parentloop.index0] == value %} selected{%- endif -%}
                >{{ option.name | upcase }}: {{ value | upcase }}</option>
              {%- endfor -%}
            </select>
          {%- endif -%}
        {%- endfor -%}
        {%- if show_swatches -%}
          {% render 'variant-swatches', product: card_product, variant: current_variant %}
        {%- endif -%}
      </div>

      <div class="product-info-shop product-card__body">
        <div class="product-card__copy">
          <span class="product-name product-card__title">
            <a href="{{ current_product_url }}">{{ card_product.title | escape }}</a>
          </span>

          {%- if subtitle != blank -%}
            <span class="product-desc product-card__subtitle">{{ subtitle | escape }}</span>
          {%- endif -%}
        </div>

        {% render 'price', product: card_product, variant: current_variant %}
      </div>

    {%- elsif card_layout == 'compact' -%}
      {%- if show_swatches -%}
        <div class="product-options product-card__options">
          {% render 'variant-swatches', product: card_product, variant: current_variant %}
        </div>
      {%- endif -%}

      <div class="product-info-shop product-card__body">
        <div class="product-card__copy">
          <span class="product-name product-card__title">
            <a href="{{ current_product_url }}">{{ card_product.title | escape }}</a>
          </span>

          {%- if subtitle != blank -%}
            <span class="product-desc product-card__subtitle">{{ subtitle | escape }}</span>
          {%- endif -%}
        </div>

        {% render 'price', product: card_product, variant: current_variant %}
      </div>

    {%- else -%}
      {%- if show_swatches -%}
        <div class="product-options product-card__options">
          {% render 'variant-swatches', product: card_product, variant: current_variant %}
        </div>
      {%- endif -%}

      <div class="product-info-stacked product-card__body">
        <div class="product-card__copy">
          <span class="product-name product-card__title">
            <a href="{{ current_product_url }}">{{ card_product.title | escape }}</a>
          </span>

          {%- if subtitle != blank -%}
            <span class="product-desc product-card__subtitle">{{ subtitle | escape }}</span>
          {%- endif -%}
        </div>

        {% render 'price', product: card_product, variant: current_variant %}
      </div>
    {%- endif -%}

    <a
      href="{{ current_product_url }}"
      class="product-btn product-card__button"
    >
      SHOP NOW
    </a>
  </product-card>
{%- endif -%}
