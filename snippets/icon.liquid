{%- liquid
  assign size = size | default: 24
-%}
{%- case name -%}
  {%- when 'search' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <circle cx="11" cy="11" r="6.5" stroke="currentColor" stroke-width="1.2"></circle>
      <path d="M16 16L20 20" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
    </svg>
  {%- when 'cart' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M7 7.5C7 4.9 9 3 12 3C15 3 17 4.9 17 7.5V9H19L18 20H6L5 9H7V7.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"></path>
      <path d="M9 9V7.5C9 6 10.2 5 12 5C13.8 5 15 6 15 7.5V9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
    </svg>
  {%- when 'account' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <circle cx="12" cy="8" r="3.5" stroke="currentColor" stroke-width="1.2"></circle>
      <path d="M5.5 19.5C6.6 16.8 8.9 15.5 12 15.5C15.1 15.5 17.4 16.8 18.5 19.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
    </svg>
  {%- when 'wishlist' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M12 20.3L4.7 12.9C2.8 11 2.8 7.9 4.7 6C6.4 4.3 9.2 4.2 11 5.8C11.4 6.1 11.7 6.4 12 6.8C12.3 6.4 12.6 6.1 13 5.8C14.8 4.2 17.6 4.3 19.3 6C21.2 7.9 21.2 11 19.3 12.9L12 20.3Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"></path>
    </svg>
  {%- when 'hamburger' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M3 6H21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
      <path d="M3 12H21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
      <path d="M3 18H21" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
    </svg>
  {%- when 'close' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M6 6L18 18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
      <path d="M18 6L6 18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
    </svg>
  {%- when 'chevron-left' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M15 6L9 12L15 18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  {%- when 'chevron-right' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  {%- when 'plus' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M12 5V19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
      <path d="M5 12H19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
    </svg>
  {%- when 'minus' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M5 12H19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
    </svg>
  {%- when 'instagram' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <rect x="5" y="5" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.2"></rect>
      <circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.2"></circle>
      <circle cx="16.5" cy="7.5" r="1" fill="currentColor"></circle>
    </svg>
  {%- when 'facebook' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M14.5 8H16.8V5.2H14.3C11.9 5.2 10.5 6.7 10.5 9.2V11.1H8.5V13.8H10.5V18.8H13.4V13.8H16L16.4 11.1H13.4V9.5C13.4 8.6 13.7 8 14.5 8Z" fill="currentColor"></path>
    </svg>
  {%- when 'tiktok' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M14.3 5.3C14.8 7 16.1 8 17.8 8.2V10.8C16.7 10.8 15.5 10.4 14.3 9.8V14.3C14.3 17 12.2 19 9.6 19C7 19 4.9 17 4.9 14.4C4.9 11.8 7 9.7 9.6 9.7C9.9 9.7 10.2 9.7 10.6 9.8V12.4C10.3 12.3 10 12.3 9.7 12.3C8.6 12.3 7.7 13.2 7.7 14.3C7.7 15.4 8.6 16.3 9.7 16.3C10.8 16.3 11.7 15.4 11.7 14.3V5H14.3V5.3Z" fill="currentColor"></path>
    </svg>
  {%- when 'pinterest' -%}
    <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M12 4.5C7.8 4.5 5 7.3 5 10.9C5 13.1 6.2 14.9 7.9 15.6C8.1 15.1 8.3 14.3 8.3 13.8C8.3 13.5 8.2 13.1 8 12.5C7.8 11.9 7.7 11.4 7.7 10.9C7.7 8.7 9.4 7 11.7 7C13.6 7 14.9 8.3 14.9 10.1C14.9 12.4 13.9 15 11.7 15C10.8 15 10.2 14.2 10.4 13.3L11.1 10.4C11.2 10.1 11.3 9.7 11.3 9.3C11.3 8.5 10.9 7.9 10 7.9C8.7 7.9 7.7 9.3 7.7 11.1C7.7 11.9 8 12.5 8 12.5L6.7 18C6.5 18.8 6.6 19.9 6.7 20.6H8.8L10 16C10.2 16.4 10.9 16.7 11.7 16.7C15.5 16.7 18 13.5 18 10.1C18 6.6 15.4 4.5 12 4.5Z" fill="currentColor"></path>
    </svg>
  {%- else -%}
    <span class="visually-hidden">{{ name }}</span>
{%- endcase -%}
