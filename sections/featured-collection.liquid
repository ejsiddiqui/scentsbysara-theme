{%- liquid
  assign featured_collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show | default: 4
-%}

{%- capture fc_splide_options -%}
{
  "type": {{ section.settings.carousel_type | default: 'slide' | json }},
  "perPage": {{ section.settings.columns_desktop | default: 4 }},
  "perMove": 1,
  "gap": "1rem",
  "autoplay": {{ section.settings.carousel_autoplay | default: false | json }},
  "interval": {{ section.settings.carousel_interval | default: 5 | times: 1000 }},
  "pauseOnHover": true,
  "drag": {{ section.settings.carousel_drag | default: true | json }},
  "arrows": false,
  "pagination": false,
  "breakpoints": {
    "1024": {
      "perPage": 3
    },
    "749": {
      "perPage": {{ section.settings.mobile_per_page | default: '1' | plus: 0 }},
      "arrows": false,
      "pagination": true
    }
  }
}
{%- endcapture -%}

<section
  id="FeaturedCollection-{{ section.id }}"
  class="section-block featured-collection color-{{ section.settings.color_scheme }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}"
  data-featured-collection
>
  <div class="container">
    <div class="section-header featured-collection__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title featured-collection__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="featured-collection__subheading text-body text-muted">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.show_navigation -%}
        <div class="section-nav featured-collection__nav" data-splide-controls-for=".featured-collection__carousel" aria-label="Collection navigation">
          <button
            type="button"
            class="section-nav-link featured-collection__nav-button"
            data-splide-control="prev"
            aria-label="Previous products"
          >
            {% render 'icon', name: 'chevron-left', size: 18 %}
            BACK
          </button>
          <button
            type="button"
            class="section-nav-link featured-collection__nav-button"
            data-splide-control="next"
            aria-label="Next products"
          >
            NEXT
            {% render 'icon', name: 'chevron-right', size: 18 %}
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      <div
        class="splide featured-collection__carousel"
        data-splide='{{ fc_splide_options }}'
        aria-label="{% if featured_collection.title != blank %}Featured products: {{ featured_collection.title | escape }}{% elsif section.settings.heading != blank %}{{ section.settings.heading | escape }}{% else %}Featured products{% endif %}"
      >
        <div class="splide__track">
          <ul class="splide__list">
            {%- for product in featured_collection.products limit: products_to_show -%}
              <li class="splide__slide">
                {%
                  render 'product-card',
                  product: product,
                  card_layout: section.settings.card_layout,
                  show_secondary_image: section.settings.show_secondary_image,
                  show_swatches: section.settings.show_swatches,
                  show_quick_add: section.settings.show_quick_add,
                  show_options: section.settings.show_options,
                  subtitle: product.metafields.custom.short_description | default: product.type
                %}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

      {%- if section.settings.show_view_all and featured_collection.products_count > products_to_show -%}
        <div class="featured-collection__footer">
          <a href="{{ featured_collection.url }}" class="btn-outline">{{ section.settings.view_all_label | escape }}</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div
        class="splide featured-collection__carousel"
        data-splide='{{ fc_splide_options }}'
        aria-label="Featured products"
      >
        <div class="splide__track">
          <ul class="splide__list">
            {%- for placeholder_index in (1..4) -%}
              {%- liquid
                assign placeholder_asset = 'she-is-grace-thumb.png'
                case placeholder_index
                  when 2
                    assign placeholder_asset = 'she-is-beauty-thumb.png'
                  when 3
                    assign placeholder_asset = 'she-is-power-thumb.png'
                  when 4
                    assign placeholder_asset = 'she-is-strength-thumb.png'
                endcase
              -%}
              <li class="splide__slide">
                <article class="product-card product-card--stacked">
                  <div class="product-card-media product-card__media-shell">
                    <a class="product-image-wrap product-card__media" href="{{ routes.all_products_collection_url }}">
                      <img
                        class="product-card__image product-card__image--primary"
                        src="{{ placeholder_asset | asset_url }}"
                        alt="Scents by Sara candle"
                        width="900"
                        height="1125"
                      >
                    </a>
                  </div>
                  <div class="product-info-stacked product-card__body">
                    <div class="product-card__copy">
                      <span class="product-name product-card__title">
                        <a href="{{ routes.all_products_collection_url }}">Scents by Sara</a>
                      </span>
                      <span class="product-desc product-card__subtitle">Select a collection in the editor</span>
                    </div>
                    <div class="product-price price" data-price>
                      <span class="price-current price__current">£20.26</span>
                    </div>
                  </div>
                  <a href="{{ routes.all_products_collection_url }}" class="product-btn product-card__button">SHOP NOW</a>
                </article>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .featured-collection {
    position: relative;
  }

  .featured-collection__header {
    align-items: flex-end;
    margin-bottom: var(--space-lg);
    gap: var(--space-md);
  }

  .featured-collection__title {
    font-size: var(--text-h3);
    font-family: var(--font-sans);
    letter-spacing: 0.08em;
  }

  .featured-collection__nav {
    flex-wrap: nowrap;
    gap: var(--space-md);
  }

  .featured-collection__nav-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .featured-collection__nav-button svg {
    width: 1rem;
    height: 1rem;
  }

  .featured-collection__carousel {
    position: relative;
  }

  .featured-collection__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .featured-collection__empty {
    padding: var(--space-xl);
    border: 1px dashed var(--color-border);
    text-align: center;
    color: var(--color-muted);
  }

  @media (max-width: 1024px) {
    .featured-collection__header {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    .featured-collection__title {
      font-size: var(--text-body);
      font-family: var(--font-sans);
      font-weight: 400;
      letter-spacing: 0.08em;
    }
  }

  /* ── Product card: typography ────────────────────────── */
  .product-card__title,
  .product-card__title a {
    font-size: var(--text-body);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: 0.1em;
  }

  .product-card__subtitle {
    font-size: var(--text-small);
    font-weight: 300;
    color: var(--color-muted);
    text-transform: capitalize;
  }

  .product-card .price__current {
    font-size: var(--text-h5);
    color: var(--color-slate);
  }

  .product-card__button {
    font-size: var(--text-small);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  /* ── Product card: swatch size override ──────────────── */
  .product-card {
    --swatch-size: 30px;
  }

  /* ── Compact layout (Tier 3) ─────────────────────────── */
  .product-card--compact .product-card__options {
    justify-content: flex-start;
    gap: 8px;
  }

  .product-card--compact .variant-swatches__swatch {
    width: 20px;
    height: 20px;
    border-color: var(--color-background);
    box-shadow: none;
    transform: none;
  }

  .product-card--compact .variant-swatches__swatch.is-active,
  .product-card--compact .variant-swatches__swatch:hover {
    transform: none;
    box-shadow: inset 0 0 0 1px var(--color-background), 0 0 0 1px var(--color-border);
  }

  /* ── Shape select (Tier 2 shop layout) ───────────────── */
  .product-card--shop .product-card__options {
    margin: 16px 0 0;
  }

  .product-card--shop .product-card__option-select {
    flex: 0 0 auto;
  }

  /* ── Mobile (≤480px) ─────────────────────────────────── */
  @media (max-width: 480px) {
    .product-card--shop .product-card__options {
      flex-wrap: wrap;
      row-gap: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BESTSELLERS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation",
      "default": true
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "Card layout",
      "default": "stacked",
      "options": [
        {
          "value": "stacked",
          "label": "Full / Stacked"
        },
        {
          "value": "shop",
          "label": "Shop / Collection"
        },
        {
          "value": "compact",
          "label": "Compact / Carousel"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show swatches",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_options",
      "label": "Show option dropdowns (e.g. Shape)",
      "info": "Displays non-colour product options as dropdown selectors on the card. Only visible when card layout is Shop.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "SHOP THE COLLECTION"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Add a custom class to the section element for section-specific CSS overrides."
    },
    {
      "type": "header",
      "content": "Carousel behaviour"
    },
    {
      "type": "select",
      "id": "carousel_type",
      "label": "Carousel type",
      "default": "slide",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "loop", "label": "Loop (infinite)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "carousel_interval",
      "label": "Autoplay interval",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "carousel_drag",
      "label": "Enable swipe / drag",
      "default": true
    },
    {
      "type": "select",
      "id": "mobile_per_page",
      "label": "Cards visible on mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
