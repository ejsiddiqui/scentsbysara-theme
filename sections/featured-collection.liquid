{%- liquid
  assign featured_collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show | default: 4
-%}

<section
  id="FeaturedCollection-{{ section.id }}"
  class="section-block featured-collection color-{{ section.settings.color_scheme }}"
  data-featured-collection
>
  <div class="container">
    <div class="section-header featured-collection__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="section-title featured-collection__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="featured-collection__subheading text-body text-muted">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- if section.settings.show_navigation -%}
      <div class="section-nav featured-collection__nav" aria-label="Collection navigation">
        <button type="button" class="section-nav-link featured-collection__nav-button" data-carousel-prev aria-label="Previous products">
          {% render 'icon', name: 'chevron-left', size: 18 %}
          BACK
        </button>
        <button type="button" class="section-nav-link featured-collection__nav-button" data-carousel-next aria-label="Next products">
          NEXT
          {% render 'icon', name: 'chevron-right', size: 18 %}
        </button>
      </div>
      {%- endif -%}
    </div>

    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      <div class="featured-collection__viewport">
        <div class="featured-collection__track">
          {%- for product in featured_collection.products limit: products_to_show -%}
            {% render 'product-card',
              product: product,
              card_layout: section.settings.card_layout,
              show_secondary_image: section.settings.show_secondary_image,
              show_swatches: section.settings.show_swatches,
              show_quick_add: section.settings.show_quick_add,
              subtitle: product.metafields.custom.short_description | default: product.type
            %}
          {%- endfor -%}
        </div>
      </div>

      {%- if section.settings.show_view_all and featured_collection.products_count > products_to_show -%}
        <div class="featured-collection__footer">
          <a href="{{ featured_collection.url }}" class="btn-outline">{{ section.settings.view_all_label | escape }}</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="featured-collection__viewport">
        <div class="featured-collection__track">
          {%- for placeholder_index in (1..4) -%}
            {%- liquid
              assign placeholder_asset = 'she-is-grace-thumb.png'
              case placeholder_index
                when 2
                  assign placeholder_asset = 'she-is-beauty-thumb.png'
                when 3
                  assign placeholder_asset = 'she-is-power-thumb.png'
                when 4
                  assign placeholder_asset = 'she-is-strength-thumb.png'
              endcase
            -%}
            <article class="product-card product-card--stacked">
              <div class="product-card-media product-card__media-shell">
                <a class="product-image-wrap product-card__media" href="{{ routes.all_products_collection_url }}">
                  <img
                    class="product-card__image product-card__image--primary"
                    src="{{ placeholder_asset | asset_url }}"
                    alt="Scents by Sara candle"
                    width="900"
                    height="1125"
                  >
                </a>
              </div>
              <div class="product-info-stacked product-card__body">
                <div class="product-card__copy">
                  <span class="product-name product-card__title">
                    <a href="{{ routes.all_products_collection_url }}">Scents by Sara</a>
                  </span>
                  <span class="product-desc product-card__subtitle">Select a collection in the editor</span>
                </div>
                <div class="product-price price" data-price>
                  <span class="price-current price__current">£20.26</span>
                </div>
              </div>
              <a href="{{ routes.all_products_collection_url }}" class="product-btn product-card__button">SHOP NOW</a>
            </article>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .featured-collection {
    position: relative;
  }

  .featured-collection__header {
    align-items: flex-end;
    margin-bottom: var(--space-lg);
    gap: var(--space-md);
  }

  .featured-collection__nav {
    flex-wrap: nowrap;
    gap: var(--space-md);
  }

  .featured-collection__nav-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .featured-collection__nav-button svg {
    width: 1rem;
    height: 1rem;
  }

  .featured-collection__viewport {
    overflow: hidden;
  }

  .featured-collection__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(0, calc((100% - (clamp(var(--space-md), 2vw, var(--space-xl)) * 3)) / 4));
    gap: clamp(var(--space-md), 2vw, var(--space-xl));
    transition: transform 0.35s ease;
  }

  .featured-collection__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  .featured-collection__empty {
    padding: var(--space-xl);
    border: 1px dashed var(--color-border);
    text-align: center;
    color: var(--color-muted);
  }

  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    min-width: 0;
  }

  .product-card__media-shell {
    position: relative;
  }

  .product-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--color-secondary-bg);
  }

  .product-card[data-card-image-ratio='square'] .product-card__media {
    aspect-ratio: 1 / 1;
  }

  .product-card[data-card-image-ratio='auto'] .product-card__media {
    aspect-ratio: 4 / 5;
  }

  .product-card__media .product-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .product-card__media .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card__image--secondary {
    opacity: 0;
  }

  .product-card.is-hovered .product-card__image--secondary,
  .product-card:focus-within .product-card__image--secondary {
    opacity: 1;
  }

  .product-card.is-hovered .product-card__image--primary,
  .product-card:focus-within .product-card__image--primary {
    opacity: 0;
  }

  .product-card__quick-add,
  .product-card__badge {
    position: absolute;
    z-index: 1;
    top: var(--space-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .product-card__quick-add {
    right: var(--space-sm);
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--color-border);
    background: var(--color-background);
  }

  .product-card__badge {
    left: var(--space-sm);
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    font-size: var(--text-xsmall, 11px);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .product-card__body {
    display: flex;
    gap: var(--space-sm);
  }

  .product-card--stacked .product-card__body {
    flex-direction: column;
    text-align: center;
  }

  .product-card--shop .product-card__body {
    align-items: flex-start;
    justify-content: space-between;
  }

  .product-card__copy {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .product-card__title,
  .product-card__title a {
    line-height: 1.15;
  }

  .product-card__subtitle {
    color: var(--color-muted);
  }

  .product-card__options {
    margin-top: -0.25rem;
  }

  .product-card .product-price {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 0 0 auto;
    align-items: flex-start;
    justify-content: flex-end;
    text-align: right;
  }

  .product-card--stacked .product-price {
    align-items: center;
    text-align: center;
    justify-content: center;
  }

  .variant-swatches {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .variant-swatches__swatch {
    width: var(--swatch-size);
    height: var(--swatch-size);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: var(--swatch-color);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.15);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  [data-swatch-shape='square'] .variant-swatches__swatch {
    border-radius: 0.25rem;
  }

  .variant-swatches__swatch.is-active,
  .variant-swatches__swatch:hover {
    transform: scale(1.06);
    box-shadow: inset 0 0 0 1px var(--color-background), 0 0 0 1px var(--color-foreground);
  }

  .product-card__button {
    align-self: stretch;
    margin-top: auto;
  }

  @media (max-width: 1024px) {
    .featured-collection__header {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 749px) {
    .featured-collection__viewport {
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scrollbar-width: none;
    }

    .featured-collection__viewport::-webkit-scrollbar {
      display: none;
    }

    .featured-collection__track {
      grid-auto-flow: column;
      grid-auto-columns: minmax(78vw, 78vw);
      width: max-content;
    }

    .featured-collection__track .product-card {
      scroll-snap-align: start;
    }
  }

  /* ── Product card: typography ────────────────────────── */
  .product-card__title,
  .product-card__title a {
    font-size: var(--text-body);
    font-weight: 400;
    line-height: 1.15;
  }

  .product-card__subtitle {
    font-size: var(--text-body-small);
    font-weight: 300;
    color: var(--color-muted);
  }

  .product-card .price__current {
    font-size: var(--text-body);
    font-weight: 400;
  }

  .product-card__button {
    font-size: var(--text-body-small);
    font-weight: 300;
    letter-spacing: 0.1em;
  }

  /* ── Product card: swatch size override ──────────────── */
  .product-card {
    --swatch-size: 30px;
  }

  /* ── Compact layout (Tier 3) ─────────────────────────── */
  .product-card--compact .product-card__body {
    align-items: flex-start;
    justify-content: space-between;
  }

  .product-card--compact .product-price {
    align-items: flex-end;
    flex: 0 0 auto;
    text-align: right;
  }

  /* ── Shape select (Tier 2 shop layout) ───────────────── */
  .product-card__option-select {
    appearance: none;
    border: 1px solid var(--color-border);
    background: transparent;
    padding: var(--space-xs) calc(var(--space-md) + var(--space-sm)) var(--space-xs) var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    background-image:
      linear-gradient(45deg, transparent 50%, currentColor 50%),
      linear-gradient(135deg, currentColor 50%, transparent 50%);
    background-position:
      calc(100% - 10px) calc(50% - 1px),
      calc(100% - 6px) calc(50% - 1px);
    background-size: 4px 4px, 4px 4px;
    background-repeat: no-repeat;
  }

  /* ── Mobile (≤480px) ─────────────────────────────────── */
  @media (max-width: 480px) {
    .product-card__button {
      display: none;
    }

    .product-card--stacked .product-card__body {
      text-align: left;
    }

    .product-card--stacked .product-price {
      align-items: flex-start;
      text-align: left;
    }
  }
{% endstylesheet %}

<script type="module">
  const featuredCollection = document.getElementById('FeaturedCollection-{{ section.id }}');

  if (featuredCollection) {
    const viewport = featuredCollection.querySelector('.featured-collection__viewport');
    const prevButton = featuredCollection.querySelector('[data-carousel-prev]');
    const nextButton = featuredCollection.querySelector('[data-carousel-next]');

    if (viewport && prevButton && nextButton) {
      const scrollByPage = (direction) => {
        viewport.scrollBy({
          left: direction * Math.max(viewport.clientWidth * 0.9, 280),
          behavior: 'smooth',
        });
      };

      prevButton.addEventListener('click', () => scrollByPage(-1));
      nextButton.addEventListener('click', () => scrollByPage(1));
    }
  }
</script>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BESTSELLERS"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation",
      "default": true
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "Card layout",
      "default": "stacked",
      "options": [
        {
          "value": "stacked",
          "label": "Full / Stacked"
        },
        {
          "value": "shop",
          "label": "Shop / Collection"
        },
        {
          "value": "compact",
          "label": "Compact / Carousel"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show secondary image on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show swatches",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "SHOP THE COLLECTION"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
