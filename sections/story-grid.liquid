{%- liquid
  assign stories = section.settings.stories
-%}

<section class="story-grid-section section-block color-{{ section.settings.color_scheme }}" id="StoryGrid-{{ section.id }}">
  <div class="container">
    <div class="story-grid-section__header flex-between items-end">
      <div>
        <h2 class="font-sans text-md font-weight-normal">{{ section.settings.heading | escape }}</h2>
      </div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
    </div>

    {%- if stories != blank and stories.size > 0 -%}
      <div class="story-grid grid-cols-3">
        {%- for story in stories -%}
          {%- liquid
            assign story_title = story.title.value | default: story.system.title | default: story.system.handle | replace: '-', ' '
            assign story_name = story.name.value
            assign story_body = story.story.value
            assign story_image = story.image.value
            assign story_product = story.product.value
            assign story_anonymous = story.anonymous.value
          -%}
          <!-- DBG_RAW:{{story}} SYS:{{story.system}} ANON_TYPE:{{story.anonymous}} -->
          <button
            class="story-card"
            type="button"
            data-story-modal-trigger="StoryModal-{{ section.id }}-{{ forloop.index }}"
          >
            <div class="story-card__media">
              {%- if story_product != blank -%}
                <span class="story-card__badge eyebrow">{{ story_product.title | escape }}</span>
              {%- endif -%}
              {%- if story_image != blank -%}
                {% render 'image',
                  image: story_image,
                  alt: story_title,
                  widths: '400,600,800',
                  sizes: '(min-width: 990px) 33vw, 100vw',
                  loading: 'lazy',
                  class: 'story-card__image'
                %}
              {%- endif -%}
            </div>

            <div class="story-card__body">
              <h3 class="story-card__title font-sans">{{ story_title | escape }}</h3>
              <p class="story-card__excerpt text-small text-muted">{{ story_body | strip_html | truncate: 140 }}</p>
              {%- unless story_anonymous -%}
                {%- if story_name != blank -%}
                  <span class="story-card__author eyebrow">{{ story_name | escape }}</span>
                {%- endif -%}
              {%- endunless -%}
            </div>
          </button>
        {%- endfor -%}
      </div>

      {%- for story in stories -%}
        {%- liquid
          assign story_title = story.title.value | default: story.system.title
          assign story_name = story.name.value
          assign story_body = story.story.value
          assign story_image = story.image.value
          assign story_product = story.product.value
          assign story_anonymous = story.anonymous.value
        -%}
        <dialog-component id="StoryModal-{{ section.id }}-{{ forloop.index }}">
          <dialog class="story-modal">
            <div class="story-modal__grid">
              {%- if story_image != blank -%}
                <div class="story-modal__media">
                  {% render 'image',
                    image: story_image,
                    alt: story_title,
                    widths: '600,900,1200',
                    sizes: '(min-width: 990px) 50vw, 100vw',
                    loading: 'lazy',
                    class: 'story-modal__image'
                  %}
                </div>
              {%- endif -%}

              <div class="story-modal__content">
                <button type="button" class="icon-btn story-modal__close" data-dialog-close aria-label="Close story">
                  {% render 'icon', name: 'close', size: 18 %}
                </button>

                {%- if story_product != blank -%}
                  <span class="eyebrow story-modal__product">{{ story_product.title | escape }}</span>
                {%- endif -%}

                <h2 class="font-serif story-modal__title">{{ story_title | escape }}</h2>

                <div class="story-modal__body text-body">{{ story_body }}</div>

                {%- unless story_anonymous -%}
                  {%- if story_name != blank -%}
                    <p class="story-modal__author eyebrow">{{ story_name | escape }}</p>
                  {%- endif -%}
                {%- endunless -%}
              </div>
            </div>
          </dialog>
        </dialog-component>
      {%- endfor -%}
    {%- else -%}
      <div class="masonry-grid grid-cols-3">
        <div class="masonry-col">
          <article class="ys-card">
            <div class="ys-img-wrap">
              <span class="ys-badge">SHE IS GRACE</span>
              <img src="{{ 'product-2.png' | asset_url }}" alt="A Moment of Grace" width="429" height="537" loading="lazy">
            </div>
            <div class="ys-content">
              <h3 class="font-sans text-md font-weight-normal mb-4">A Moment of Grace</h3>
              <p class="text-sm text-muted mb-8">
                The first time I lit She Is Grace, I felt something shift. The scent carried me back to my grandmother's garden in Lagos, warm jasmine and soft earth. I cried, then smiled. It was a memory I didn't know I'd been carrying.
              </p>
              <span class="ys-author text-micro text-muted uppercase tracking-widest">AMARA OSEI</span>
            </div>
          </article>

          <article class="ys-card">
            <div class="ys-img-wrap">
              <span class="ys-badge">SHE IS POWER</span>
              <img src="{{ 'product-4.png' | asset_url }}" alt="The Gift That Said Everything" width="429" height="537" loading="lazy">
            </div>
            <div class="ys-content">
              <h3 class="font-sans text-md font-weight-normal mb-4">The Gift That Said Everything</h3>
              <p class="text-sm text-muted mb-8">
                I gifted She Is Power to my sister on the day she was promoted. She messaged me an hour later, weeping. She said it smelled like the version of herself she had always been trying to become.
              </p>
              <span class="ys-author text-micro text-muted uppercase tracking-widest">NADIA IBRAHIM</span>
            </div>
          </article>
        </div>

        <div class="masonry-col">
          <article class="ys-card">
            <div class="ys-img-wrap">
              <span class="ys-badge">THE LIVED-IN BODY</span>
              <img src="{{ 'product-1.png' | asset_url }}" alt="Reclaiming My Body" width="429" height="537" loading="lazy">
            </div>
            <div class="ys-content">
              <h3 class="font-sans text-md font-weight-normal mb-4">Reclaiming My Body</h3>
              <p class="text-sm text-muted mb-8">
                After years of feeling disconnected from myself, the Lived-In Body Collection became part of my morning ritual. Seeing the gold leaf celebrate the curves I once hid changed how I saw my own reflection.
              </p>
              <span class="ys-author text-micro text-muted uppercase tracking-widest">CLAIRE DEVEREUX</span>
            </div>
          </article>

          <article class="ys-card">
            <div class="ys-img-wrap">
              <span class="ys-badge">SHE IS STRENGTH</span>
              <img src="{{ 'product-3.png' | asset_url }}" alt="Strength in Stillness" width="429" height="537" loading="lazy">
            </div>
            <div class="ys-content">
              <h3 class="font-sans text-md font-weight-normal mb-4">Strength in Stillness</h3>
              <p class="text-sm text-muted mb-8">
                In the quiet after my surgery, She Is Strength sat on my bedside table. I couldn't explain why it helped, but it did. It reminded me that beauty and healing could exist in the same moment.
              </p>
              <span class="ys-author text-micro text-muted uppercase tracking-widest">PRIYA MEHTA</span>
            </div>
          </article>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<script type="module">
  const storyGridRoot = document.getElementById('StoryGrid-{{ section.id }}');

  if (storyGridRoot && storyGridRoot.dataset.storyGridInitialised !== 'true') {
    storyGridRoot.dataset.storyGridInitialised = 'true';

    storyGridRoot.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-story-modal-trigger]');
      if (!trigger) {
        return;
      }

      const modal = document.getElementById(trigger.dataset.storyModalTrigger);
      modal?.open?.();
    });
  }
</script>

{% stylesheet %}
  .story-grid-section {
    max-width: 1920px;
    margin-inline: auto;
    padding-top: 0;
    padding-right: var(--gutter);
    padding-bottom: 64px;
    padding-left: var(--gutter);
  }

  .story-grid-section > .container {
    width: 100%;
    max-width: none;
    padding-inline: 0;
  }

  .story-grid-section__header {
    margin-bottom: var(--space-lg);
    gap: 1rem;
  }

  .story-grid-section__header h2 {
    margin: 0;
  }

  .story-grid-section__header .eyebrow {
    font-size: var(--text-micro);
    line-height: 1;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .story-grid {
    gap: var(--space-lg);
  }

  .story-card {
    display: grid;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    padding: 0;
    text-align: left;
    color: inherit;
    cursor: pointer;
    transition: box-shadow 0.2s ease;
  }

  .story-card:hover {
    box-shadow: 0 4px 24px rgba(63, 50, 41, 0.1);
  }

  .story-card__media {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--color-secondary-bg);
    overflow: hidden;
  }

  .story-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    background: var(--color-foreground);
    color: var(--color-background);
    padding: 0.25rem 0.625rem;
    font-size: var(--text-micro);
    letter-spacing: 0.12em;
  }

  .story-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .story-card:hover .story-card__image {
    transform: scale(1.03);
  }

  .story-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: grid;
    gap: 0.5rem;
  }

  .story-card__title {
    margin: 0;
    font-size: var(--text-body-large);
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .story-card__excerpt {
    margin: 0;
    line-height: 1.65;
  }

  .story-card__author {
    display: block;
    margin-top: 0.25rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: var(--text-micro);
    color: var(--color-muted);
    letter-spacing: 0.12em;
  }

  .story-grid__empty {
    border: 1px dashed var(--color-border);
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-muted);
  }

  .masonry-grid {
    gap: 32px;
  }

  .masonry-col {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .ys-card {
    display: flex;
    flex-direction: column;
    margin-bottom: 32px;
  }

  .ys-img-wrap {
    position: relative;
    overflow: hidden;
    background: var(--color-secondary-bg);
  }

  .ys-img-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  .ys-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    padding: 4px 8px;
    background: var(--text-primary);
    color: var(--text-on-dark);
    font-size: var(--text-micro);
    letter-spacing: 0.1em;
  }

  .ys-content {
    display: flex;
    flex-direction: column;
    min-height: 239px;
    padding: 40px;
  }

  .masonry-col:first-child .ys-content {
    background: var(--bg-secondary);
  }

  .masonry-col:last-child .ys-content {
    background: var(--bg-primary);
  }

  .ys-author {
    display: block;
    padding-top: 16px;
    border-top: 1px solid var(--border-light);
    font-size: var(--text-micro);
  }

  .story-modal {
    width: min(72rem, calc(100vw - 2rem));
    max-height: calc(100svh - 2rem);
    border: 0;
    padding: 0;
    overflow: hidden;
  }

  .story-modal::backdrop {
    background: rgba(45, 43, 39, 0.5);
  }

  .story-modal__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: min(38rem, 80svh);
    max-height: calc(100svh - 2rem);
    overflow: hidden;
  }

  .story-modal__media {
    position: relative;
    overflow: hidden;
    background: var(--color-secondary-bg);
  }

  .story-modal__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .story-modal__content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 3rem 2.5rem;
    background: var(--color-background);
    overflow-y: auto;
  }

  .story-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }

  .story-modal__product {
    font-size: var(--text-micro);
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }

  .story-modal__title {
    margin: 0;
    font-size: var(--text-h3);
    line-height: 1.2;
  }

  .story-modal__body {
    flex: 1;
    line-height: 1.75;
    color: var(--color-foreground);
  }

  .story-modal__author {
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: var(--text-micro);
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }

  @media (max-width: 749px) {
    .story-modal__grid {
      grid-template-columns: 1fr;
    }

    .story-modal__media {
      aspect-ratio: 3 / 2;
      position: relative;
    }

    .story-modal__image {
      position: absolute;
    }

    .story-modal__content {
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 749px) {
    .story-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .masonry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .story-grid {
      grid-template-columns: 1fr;
    }

    .masonry-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) {
    .story-grid-section__header {
      padding-bottom: 4px;
    }
  }

  @media (max-width: 1440px) {
    .ys-content {
      min-height: 254px;
    }
  }

  @media (max-width: 1024px) {
    .ys-content {
      min-height: 276px;
    }
  }

  @media (max-width: 768px) {
    .story-grid-section {
      padding-right: var(--gutter);
      padding-left: var(--gutter);
    }

    .ys-content {
      min-height: 290px;
      padding: 28px;
    }
  }

  @media (max-width: 480px) {
    .story-grid-section {
      padding-top: 0;
      padding-bottom: 64px;
    }

    .story-grid-section__header {
      padding-bottom: 3px;
    }

    .ys-card {
      margin-bottom: 24px;
    }

    .ys-content {
      min-height: 239px;
    }
  }

  @media (max-width: 390px) {
    .ys-card {
      margin-bottom: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Story grid",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOUR STORIES"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "AS TOLD BY OUR COMMUNITY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every candle tells a story. These are yours, shared moments of transformation, memory, and quiet power."
    },
    {
      "type": "metaobject_list",
      "id": "stories",
      "label": "Stories",
      "metaobject_type": "customer_story"
    }
  ],
  "presets": [
    {
      "name": "Story grid"
    }
  ]
}
{% endschema %}
