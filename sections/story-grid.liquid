{%- liquid
  assign stories = section.settings.stories.value
-%}

<section class="story-grid-section section-block color-{{ section.settings.color_scheme }}" id="StoryGrid-{{ section.id }}">
  <div class="container">
    <div class="story-grid-section__header flex-between items-end">
      <div>
        <h2 class="font-serif text-h2">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="text-body text-muted">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
    </div>

    {%- if stories != blank and stories.count > 0 -%}
      <div class="story-grid grid-cols-2">
        {%- for story in stories -%}
          {%- liquid
            assign story_name = story.name.value | default: story.system.title
            assign story_body = story.story.value
            assign story_image = story.image.value
            assign story_product = story.product.value
          -%}
          <button
            class="story-card"
            type="button"
            data-story-modal-trigger="StoryModal-{{ section.id }}-{{ forloop.index }}"
          >
            {%- if story_image != blank -%}
              <div class="story-card__media">
                {% render 'image',
                  image: story_image,
                  alt: story_name,
                  widths: '400,600,800',
                  sizes: '(min-width: 990px) 40vw, 100vw',
                  loading: 'lazy',
                  class: 'story-card__image'
                %}
              </div>
            {%- endif -%}

            <div class="story-card__body">
              {%- if story_product != blank -%}
                <span class="eyebrow">{{ story_product.title | escape }}</span>
              {%- endif -%}
              <h3 class="story-card__title">{{ story_name | escape }}</h3>
              <p class="story-card__excerpt text-small text-muted">{{ story_body | strip_html | truncate: 160 }}</p>
            </div>
          </button>
        {%- endfor -%}
      </div>

      {%- for story in stories -%}
        {%- liquid
          assign story_name = story.name.value | default: story.system.title
          assign story_body = story.story.value
          assign story_image = story.image.value
          assign story_product = story.product.value
        -%}
        <dialog-component id="StoryModal-{{ section.id }}-{{ forloop.index }}">
          <dialog class="story-modal">
            <div class="story-modal__content">
              <button type="button" class="icon-btn story-modal__close" data-dialog-close aria-label="Close story">
                {% render 'icon', name: 'close', size: 18 %}
              </button>

              {%- if story_image != blank -%}
                {% render 'image',
                  image: story_image,
                  alt: story_name,
                  widths: '600,900,1200',
                  sizes: '(min-width: 990px) 48rem, 100vw',
                  loading: 'lazy',
                  class: 'story-modal__image'
                %}
              {%- endif -%}

              {%- if story_product != blank -%}
                <span class="eyebrow">{{ story_product.title | escape }}</span>
              {%- endif -%}

              <h3 class="font-serif text-h3">{{ story_name | escape }}</h3>
              <div class="story-modal__body text-body">{{ story_body }}</div>
            </div>
          </dialog>
        </dialog-component>
      {%- endfor -%}
    {%- else -%}
      <div class="story-grid__empty">
        Add approved customer stories from the `customer_story` metaobject to populate this section.
      </div>
    {%- endif -%}
  </div>
</section>

<script type="module">
  const storyGridRoot = document.getElementById('StoryGrid-{{ section.id }}');

  if (storyGridRoot && storyGridRoot.dataset.storyGridInitialised !== 'true') {
    storyGridRoot.dataset.storyGridInitialised = 'true';

    storyGridRoot.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-story-modal-trigger]');
      if (!trigger) {
        return;
      }

      const modal = document.getElementById(trigger.dataset.storyModalTrigger);
      modal?.open?.();
    });
  }
</script>

{% stylesheet %}
  .story-grid-section__header {
    margin-bottom: var(--space-lg);
    gap: 1rem;
  }

  .story-grid {
    gap: var(--space-lg);
  }

  .story-card {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    padding: 0;
    text-align: left;
    color: inherit;
    cursor: pointer;
  }

  .story-card__media {
    aspect-ratio: 4 / 5;
    background: var(--color-secondary-bg);
  }

  .story-card__image,
  .story-modal__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-card__body {
    padding: 1.25rem;
  }

  .story-card__title {
    margin: 0.5rem 0;
    font-size: var(--text-h4);
  }

  .story-grid__empty {
    border: 1px dashed var(--color-border);
    padding: var(--space-xl);
    text-align: center;
    color: var(--color-muted);
  }

  .story-modal {
    width: min(48rem, calc(100vw - 2rem));
    border: 0;
    padding: 0;
  }

  .story-modal::backdrop {
    background: rgba(45, 43, 39, 0.45);
  }

  .story-modal__content {
    position: relative;
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--color-background);
  }

  .story-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }

  @media (max-width: 749px) {
    .story-grid-section__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .story-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Story grid",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOUR STORIES"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "AS TOLD BY OUR COMMUNITY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every candle tells a story. These are yours, shared moments of transformation, memory, and quiet power."
    },
    {
      "type": "metaobject_list",
      "id": "stories",
      "label": "Stories",
      "metaobject_type": "customer_story"
    }
  ],
  "presets": [
    {
      "name": "Story grid"
    }
  ]
}
{% endschema %}
