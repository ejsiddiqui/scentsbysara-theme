<section class="contact-section section-block color-{{ section.settings.color_scheme }}">
  <div class="container contact-section__grid grid-cols-2">
    <aside class="contact-section__info">
      <span class="eyebrow">{{ section.settings.info_eyebrow | escape }}</span>
      <h1 class="font-serif text-h2">{{ section.settings.heading | escape }}</h1>

      {%- if section.settings.description != blank -%}
        <div class="text-body text-muted">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="contact-section__info-list" role="list">
          {%- for block in section.blocks -%}
            <li class="contact-section__info-item" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                {% render 'image',
                  image: block.settings.icon,
                  alt: block.settings.title,
                  sizes: '40px',
                  widths: '40,80',
                  loading: 'lazy',
                  class: 'contact-section__info-icon'
                %}
              {%- endif -%}

              <div>
                <h3>{{ block.settings.title | escape }}</h3>
                <div class="text-small text-muted">{{ block.settings.content }}</div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </aside>

    <div class="contact-section__form-shell">
      <span class="eyebrow">{{ section.settings.form_eyebrow | escape }}</span>

      {%- form 'contact', id: 'contact-form', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-success" role="status">Thank you for your message. We will get back to you soon.</p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="form-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="grid-cols-2 contact-form__grid">
          <div class="form-group">
            <label for="ContactName-{{ section.id }}" class="form-label">NAME</label>
            <input id="ContactName-{{ section.id }}" type="text" name="contact[name]" class="form-input" required autocomplete="name">
          </div>

          <div class="form-group">
            <label for="ContactEmail-{{ section.id }}" class="form-label">EMAIL</label>
            <input id="ContactEmail-{{ section.id }}" type="email" name="contact[email]" class="form-input" required autocomplete="email">
          </div>
        </div>

        <div class="form-group">
          <label for="ContactSubject-{{ section.id }}" class="form-label">SUBJECT</label>
          <input id="ContactSubject-{{ section.id }}" type="text" name="contact[subject]" class="form-input">
        </div>

        <div class="form-group">
          <label for="ContactMessage-{{ section.id }}" class="form-label">MESSAGE</label>
          <textarea id="ContactMessage-{{ section.id }}" name="contact[body]" class="form-input contact-form__textarea" rows="7" required></textarea>
        </div>

        <button type="submit" class="btn-solid">SEND MESSAGE</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .contact-section__grid {
    gap: var(--space-xl);
  }

  .contact-section__info,
  .contact-section__form-shell {
    display: grid;
    gap: 1rem;
  }

  .contact-section__info-list {
    display: grid;
    gap: 1rem;
  }

  .contact-section__info-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
  }

  .contact-section__info-icon {
    width: 2.5rem;
    height: 2.5rem;
    object-fit: contain;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .contact-form__grid {
    gap: 1rem;
  }

  .contact-form__textarea {
    min-height: 12rem;
  }

  @media (max-width: 749px) {
    .contact-form__grid,
    .contact-section__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "info_eyebrow",
      "label": "Info eyebrow",
      "default": "GET IN TOUCH"
    },
    {
      "type": "text",
      "id": "form_eyebrow",
      "label": "Form eyebrow",
      "default": "SEND A MESSAGE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LET US SUPPORT YOUR RITUAL"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our team replies within one to two business days. For order issues, include your order number for faster help.</p>"
    }
  ],
  "blocks": [
    {
      "type": "info_block",
      "name": "Info block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Email"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>hello@scentsbysara.com</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact form",
      "blocks": [
        {
          "type": "info_block",
          "settings": {
            "title": "Email",
            "content": "<p>hello@scentsbysara.com</p>"
          }
        },
        {
          "type": "info_block",
          "settings": {
            "title": "WhatsApp",
            "content": "<p>+44 20 1234 5678</p>"
          }
        },
        {
          "type": "info_block",
          "settings": {
            "title": "Studio hours",
            "content": "<p>Monday to Friday, 9:00 to 18:00 GMT</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
