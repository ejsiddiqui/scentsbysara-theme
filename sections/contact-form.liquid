<section class="contact-section section-block color-{{ section.settings.color_scheme }}">
  <div class="container contact-section__grid contact-grid grid-cols-2">
    <aside class="contact-section__info contact-info-panel">
      <span class="eyebrow">{{ section.settings.info_eyebrow | escape }}</span>
      <h1 class="text-h2">{{ section.settings.heading | escape }}</h1>

      {%- if section.settings.description != blank -%}
        <div class="text-body text-muted">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="contact-section__info-list contact-info-list" role="list">
          {%- for block in section.blocks -%}
            <li class="contact-section__info-item" {{ block.shopify_attributes }}>
              <div>
                <h3>{{ block.settings.title | escape }}</h3>
                <div class="text-small text-muted">{{ block.settings.content }}</div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="contact-section__socials" aria-label="Social media">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" class="contact-section__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">{% render 'icon', name: 'instagram', size: 20 %}</a>
        {%- endif -%}
        {%- if settings.social_facebook != blank -%}
          <a href="{{ settings.social_facebook }}" class="contact-section__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">{% render 'icon', name: 'facebook', size: 20 %}</a>
        {%- endif -%}
        {%- if settings.social_tiktok != blank -%}
          <a href="{{ settings.social_tiktok }}" class="contact-section__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer">{% render 'icon', name: 'tiktok', size: 20 %}</a>
        {%- endif -%}
        {%- if settings.social_pinterest != blank -%}
          <a href="{{ settings.social_pinterest }}" class="contact-section__social-link" aria-label="Pinterest" target="_blank" rel="noopener noreferrer">{% render 'icon', name: 'pinterest', size: 20 %}</a>
        {%- endif -%}
      </div>
    </aside>

    <div class="contact-section__form-shell contact-form-panel">
      <span class="eyebrow">{{ section.settings.form_eyebrow | escape }}</span>

      {%- form 'contact', id: 'contact-form', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-success" role="status">Thank you for your message. We will get back to you soon.</p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="form-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="contact-form__name-row">
          <div class="form-group">
            <label for="ContactFirstName-{{ section.id }}" class="form-label">FIRST NAME</label>
            <input
              id="ContactFirstName-{{ section.id }}"
              type="text"
              name="contact[first_name]"
              class="form-input"
              required
              minlength="1"
              maxlength="40"
              autocomplete="given-name"
            >
            <p class="field-error" data-for="first_name" aria-live="polite"></p>
          </div>
          <div class="form-group">
            <label for="ContactLastName-{{ section.id }}" class="form-label">LAST NAME</label>
            <input
              id="ContactLastName-{{ section.id }}"
              type="text"
              name="contact[last_name]"
              class="form-input"
              required
              minlength="1"
              maxlength="40"
              autocomplete="family-name"
            >
            <p class="field-error" data-for="last_name" aria-live="polite"></p>
          </div>
        </div>

        <div class="form-group">
          <label for="ContactEmail-{{ section.id }}" class="form-label">EMAIL ADDRESS</label>
          <input
            id="ContactEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            class="form-input"
            required
            maxlength="120"
            autocomplete="email"
          >
          <p class="field-error" data-for="email" aria-live="polite"></p>
        </div>

        <div class="form-group">
          <label for="ContactTopic-{{ section.id }}" class="form-label">TOPIC</label>
          <input
            id="ContactTopic-{{ section.id }}"
            type="text"
            name="contact[topic]"
            class="form-input"
            placeholder=""
            maxlength="120"
          >
          <p class="field-error" data-for="topic" aria-live="polite"></p>
        </div>

        <div class="form-group">
          <label for="ContactMessage-{{ section.id }}" class="form-label">MESSAGE</label>
          <textarea
            id="ContactMessage-{{ section.id }}"
            name="contact[body]"
            class="form-input contact-form__textarea"
            rows="9"
            required
            minlength="20"
            maxlength="1200"
          ></textarea>
          <div class="form-meta">
            <span class="char-count">0 / 1200</span>
          </div>
          <p class="field-error" data-for="message" aria-live="polite"></p>
        </div>

        <button type="submit" class="btn-solid">SUBMIT</button>
        <p class="form-status" aria-live="polite"></p>
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .contact-section {
    max-width: 1920px;
    margin-inline: auto;
    padding: 96px var(--gutter);
  }

  .contact-section__grid {
    align-items: start;
    gap: 64px;
    padding-inline: 0;
  }

  .contact-info-panel {
    padding: 48px;
    border: 1px solid var(--border-light);
    background: var(--bg-secondary);
  }

  .contact-info-panel h1 {
    font-size: var(--text-h2);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .contact-info-panel .text-body {
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .contact-info-list {
    display: grid;
    gap: 24px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-section__info-item {
    display: block;
    padding-top: 18px;
    border-top: 1px solid var(--border-light);
  }

  .contact-section__info-item h3 {
    font-family: var(--font-sans);
    font-size: var(--text-micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }

  .contact-section__info-item .text-muted {
    color: var(--color-muted);
    line-height: 1.6;
  }

  .contact-form-panel {
    padding: 8px 0;
  }

  .contact-form {
    display: grid;
    gap: 14px;
  }

  .contact-form .form-label {
    font-size: var(--text-micro);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .contact-form .form-input {
    border: 1px solid var(--border-heavy);
    padding: 14px 16px;
  }

  .contact-form__name-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .contact-form__textarea {
    min-height: 190px;
    resize: vertical;
  }

  .form-meta {
    display: flex;
    justify-content: flex-end;
    margin-top: 6px;
  }

  .contact-section .btn-solid {
    justify-self: start;
    padding: 12px 60px;
  }

  .contact-section__socials {
    display: flex;
    gap: 1.25rem;
    margin-top: var(--space-lg);
  }

  .contact-section__social-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-foreground);
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .contact-section__social-link:hover {
    opacity: 1;
  }

  @media (max-width: 1024px) {
    .contact-section__grid {
      gap: 32px;
    }

    .contact-info-panel {
      padding: 40px;
    }
  }

  @media (max-width: 768px) {
    .contact-section {
      padding-top: 72px;
      padding-bottom: 72px;
    }

    .contact-info-panel {
      padding: 30px;
    }
  }

  @media (max-width: 480px) {
    .contact-section__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    
    .contact-form__name-row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "info_eyebrow",
      "label": "Info eyebrow",
      "default": "GET IN TOUCH"
    },
    {
      "type": "text",
      "id": "form_eyebrow",
      "label": "Form eyebrow",
      "default": "SEND A MESSAGE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LET US SUPPORT YOUR RITUAL"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Our team replies within one to two business days. For order issues, include your order number for faster help.</p>"
    }
  ],
  "blocks": [
    {
      "type": "info_block",
      "name": "Info block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Email"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>hello@scentsbysara.com</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact form",
      "blocks": [
        {
          "type": "info_block",
          "settings": {
            "title": "Email",
            "content": "<p>hello@scentsbysara.com</p>"
          }
        },
        {
          "type": "info_block",
          "settings": {
            "title": "WhatsApp",
            "content": "<p>+44 20 1234 5678</p>"
          }
        },
        {
          "type": "info_block",
          "settings": {
            "title": "Studio hours",
            "content": "<p>Monday to Friday, 9:00 to 18:00 GMT</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
