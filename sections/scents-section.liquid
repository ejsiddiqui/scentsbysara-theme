{%- liquid
  assign section_heading = section.settings.heading | default: 'SCENTS'
-%}

<section class="scents-section" aria-labelledby="scents-section-title-{{ section.id }}">
  <style>
    #shopify-section-{{ section.id }} {
      --scents-section-bg: var(--color-background, #f9f6f2);
      --scents-section-text: var(--color-foreground, #3f3229);
      --scents-section-muted: var(--color-muted, #a39382);
      --scents-section-border: var(--color-border, #cec5b8);
      --scents-section-card-bg: var(--color-secondary-bg, #e7e3dc);
      --scents-section-gap: clamp(1rem, 2vw, 1.5rem);
      --scents-section-columns: {{ section.settings.columns_desktop }};
      background: var(--scents-section-bg);
      color: var(--scents-section-text);
    }

    #shopify-section-{{ section.id }} .scents-section__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: clamp(2.5rem, 5vw, 4.5rem) clamp(1rem, 4vw, 2.5rem);
    }

    #shopify-section-{{ section.id }} .scents-section__heading {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: clamp(1.25rem, 1vw + 1rem, 1.75rem);
      line-height: 1.1;
    }

    #shopify-section-{{ section.id }} .scents-section__intro {
      margin: 0.75rem 0 0;
      max-width: 42rem;
      color: var(--scents-section-muted);
      font-size: 1rem;
      line-height: 1.7;
    }

    #shopify-section-{{ section.id }} .scents-section__grid {
      display: grid;
      grid-template-columns: repeat(var(--scents-section-columns), minmax(0, 1fr));
      gap: var(--scents-section-gap);
      margin-top: 2rem;
    }

    #shopify-section-{{ section.id }} .scents-section__card {
      background: var(--scents-section-card-bg);
      border: 1px solid var(--scents-section-border);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      min-height: 100%;
    }

    #shopify-section-{{ section.id }} .scents-section__media {
      position: relative;
      aspect-ratio: 1 / 1;
      background: rgba(255, 255, 255, 0.16);
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .scents-section__media img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .scents-section__body {
      padding: 1.25rem;
      display: grid;
      gap: 0.75rem;
    }

    #shopify-section-{{ section.id }} .scents-section__name {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.875rem;
      line-height: 1.3;
    }

    #shopify-section-{{ section.id }} .scents-section__description {
      margin: 0;
      color: var(--scents-section-muted);
      font-size: 0.95rem;
      line-height: 1.7;
    }

    #shopify-section-{{ section.id }} .scents-section__empty {
      margin-top: 1.5rem;
      padding: 1rem 1.25rem;
      border: 1px dashed var(--scents-section-border);
      color: var(--scents-section-muted);
      background: rgba(255, 255, 255, 0.35);
    }

    @media (max-width: 749px) {
      #shopify-section-{{ section.id }} {
        --scents-section-columns: 1;
      }
    }

    @media (min-width: 750px) {
      #shopify-section-{{ section.id }} .scents-section__grid {
        align-items: stretch;
      }
    }
  </style>

  <div class="scents-section__inner">
    <h2 class="scents-section__heading" id="scents-section-title-{{ section.id }}">
      {{ section_heading | escape }}
    </h2>

    {%- if section.settings.intro != blank -%}
      <div class="scents-section__intro rte">
        {{ section.settings.intro }}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="scents-section__grid" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign scent_name = block.settings.name | default: 'Scent'
            assign scent_description = block.settings.description
          -%}
          <article class="scents-section__card" role="listitem" {{ block.shopify_attributes }}>
            <div class="scents-section__media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    alt: scent_name,
                    loading: 'lazy',
                    widths: '360, 540, 720, 900, 1200',
                    sizes: '(min-width: 750px) 50vw, 100vw'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="scents-section__body">
              <h3 class="scents-section__name">{{ scent_name | escape }}</h3>
              {%- if scent_description != blank -%}
                <div class="scents-section__description rte">
                  {{ scent_description }}
                </div>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- elsif request.design_mode -%}
      <div class="scents-section__empty" role="status">
        Add scent blocks in the theme editor to display the product scent cards.
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Scents section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SCENTS"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "scent",
      "name": "Scent",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Vanilla"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scents section",
      "blocks": [
        {
          "type": "scent",
          "settings": {
            "name": "Vanilla"
          }
        },
        {
          "type": "scent",
          "settings": {
            "name": "Lavender"
          }
        }
      ]
    }
  ]
}
{% endschema %}
