{%- liquid
  assign section_heading = section.settings.heading | default: 'WHAT OUR CUSTOMERS ARE SAYING'
-%}

<section
  id="ReviewsPlaceholder-{{ section.id }}"
  class="section-block reviews-placeholder"
  role="region"
  aria-labelledby="ReviewsPlaceholderHeading-{{ section.id }}"
>
  <div class="container reviews-placeholder__container">
    <header class="reviews-placeholder__header">
      <h2 id="ReviewsPlaceholderHeading-{{ section.id }}" class="section-title font-serif text-h3">
        {{ section_heading | escape }}
      </h2>
    </header>

    <div id="judgeme-reviews" class="jdgm-widget jdgm-review-widget reviews-placeholder__widget" data-judgeme-reviews>
      {% content_for 'blocks' %}
      <p class="reviews-placeholder__message">
        Reviews will appear here once the Judge.me app is installed and connected.
      </p>
    </div>
  </div>
</section>
<!-- Start of Judge.me code -->
{% assign has_legacy = false %}
{% if product.metafields.judgeme.widget.size > 20 %}
  {% assign has_legacy = true %}
{% endif %}
<div style='clear:both'></div>
  <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' 
    data-product-title='{{ product.title | escape }}' 
    data-id='{{ product.id }}' 
    data-product-id='{{ product.id }}' 
    data-widget='review' 
    data-auto-install='false' 
    data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}' 
    data-entry-point='review_widget.js' 
    data-entry-key='review-widget/main.js'>
    {% if has_legacy %}
      <div class='jdgm-legacy-widget-content' style='display: none;'>{{ product.metafields.judgeme.widget }}</div>
    {% endif %}
  </div>
    {% if product.metafields.judgeme.review_widget_data %}
      <script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ product.id }}] = {{ product.metafields.judgeme.review_widget_data }}</script>
{% endif %}
<!-- End of Judge.me code -->

{% stylesheet %}
  .reviews-placeholder__header {
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .reviews-placeholder__widget {
    min-height: 120px;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    background: var(--color-secondary-bg);
  }

  .reviews-placeholder__message {
    margin: 0;
    color: var(--color-muted);
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Reviews placeholder",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHAT OUR CUSTOMERS ARE SAYING"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Reviews placeholder"
    }
  ]
}
{% endschema %}
