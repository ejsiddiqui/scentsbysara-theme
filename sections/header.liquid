{%- liquid
  assign header_logo = section.settings.logo | default: settings.logo
  assign header_logo_mobile = section.settings.logo_mobile | default: settings.logo_mobile | default: header_logo
  assign main_menu = section.settings.menu
  assign account_url = routes.account_login_url
  if customer
    assign account_url = routes.account_url
  endif
-%}

<header-component
  class="header-shell{% if section.settings.enable_transparent and request.page_type == 'index' %} header-shell--transparent{% endif %}"
  data-sticky-mode="{{ section.settings.sticky_header }}"
  data-cart-type="{{ settings.cart_type }}"
  data-section-id="{{ section.id }}"
>
  <header class="site-header color-{{ section.settings.color_scheme | default: 'scheme-1' }}">
    <div class="header-top container">
      <div class="header-left">
        <button
          type="button"
          class="icon-btn header-action header-action--search desktop-only-inline"
          aria-label="{{ 'general.search' | t }}"
          data-open-search
        >
          {% render 'icon', name: 'search' %}
        </button>
        <button
          type="button"
          class="icon-btn header-action header-action--search mobile-only-inline"
          aria-label="{{ 'general.search' | t }}"
          data-open-search
        >
          {% render 'icon', name: 'search' %}
        </button>
        <a
          href="{{ routes.cart_url }}"
          class="icon-btn header-action header-action--cart mobile-only-inline"
          aria-label="{{ 'general.cart' | t }}"
          data-open-cart
        >
          {% render 'icon', name: 'cart' %}
          <span class="header-cart-badge{% if cart.item_count == 0 %} is-hidden{% endif %}">
            {{ cart.item_count }}
          </span>
        </a>
      </div>

      <div class="header-centre">
        <a href="{{ routes.root_url }}" class="logo logo-long" aria-label="{{ shop.name }}">
          {%- if header_logo != blank -%}
            {{
              header_logo
              | image_url: width: 420
              | image_tag:
                class: 'header-logo-image',
                widths: '200,300,420',
                sizes: '(min-width: 990px) 240px, 180px',
                loading: 'eager',
                alt: shop.name
            }}
          {%- else -%}
            <span class="font-serif text-h4">{{ shop.name }}</span>
          {%- endif -%}
        </a>
        <a href="{{ routes.root_url }}" class="logo logo-symbol" aria-label="{{ shop.name }}">
          {%- if header_logo_mobile != blank -%}
            {{
              header_logo_mobile
              | image_url: width: 160
              | image_tag:
                class: 'header-logo-image',
                widths: '80,120,160',
                sizes: '56px',
                loading: 'eager',
                alt: shop.name
            }}
          {%- else -%}
            <span class="font-serif text-h6">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <div class="header-right nav-icons">
        <a
          href="{{ account_url }}"
          class="icon-btn header-action desktop-only-inline"
          aria-label="{{ 'general.account' | t }}"
        >
          {% render 'icon', name: 'account' %}
        </a>
        <a
          href="{{ routes.all_products_collection_url }}"
          class="icon-btn header-action desktop-only-inline"
          aria-label="{{ 'general.wishlist' | t }}"
        >
          {% render 'icon', name: 'wishlist' %}
        </a>
        <a
          href="{{ routes.cart_url }}"
          class="icon-btn header-action desktop-only-inline"
          aria-label="{{ 'general.cart' | t }}"
          data-open-cart
        >
          {% render 'icon', name: 'cart' %}
          <span class="header-cart-badge{% if cart.item_count == 0 %} is-hidden{% endif %}">
            {{ cart.item_count }}
          </span>
        </a>
        <button
          type="button"
          class="icon-btn header-action mobile-only-inline"
          aria-label="{{ 'accessibility.open_menu' | t }}"
          aria-controls="MobileMenu-{{ section.id }}"
          aria-expanded="false"
          data-open-mobile-menu
        >
          {% render 'icon', name: 'hamburger' %}
        </button>
      </div>
    </div>

    <div class="header-bottom desktop-only-block">
      <nav class="header-nav container" aria-label="{{ 'general.primary_navigation' | t }}">
        <ul class="header-nav-list" role="list">
          {%- for link in linklists[main_menu].links -%}
            <li
              class="header-nav-item{% if link.links.size > 0 %} has-mega-menu{% endif %}"
              {% if link.links.size > 0 %}
                data-nav-item-has-children
              {% endif %}
            >
              <a href="{{ link.url }}" class="header-nav-link">
                {{ link.title }}
              </a>
              {%- if link.links.size > 0 -%}
                {% render 'mega-menu',
                  link: link,
                  featured_image: section.settings.mega_menu_featured_image,
                  featured_link: section.settings.mega_menu_featured_link
                %}
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    </div>

    {% render 'search-modal', section_id: section.id %}

    <mobile-menu id="MobileMenu-{{ section.id }}" aria-label="{{ 'general.mobile_menu' | t }}">
      <dialog class="mobile-menu-dialog" ref="dialog" aria-modal="true" aria-label="{{ 'general.mobile_menu' | t }}">
        <div class="mobile-menu-content">
          <div class="mobile-menu-top">
            <a href="{{ routes.root_url }}" class="mobile-menu-brand" aria-label="{{ shop.name }}">
              {%- if header_logo != blank -%}
                {{
                  header_logo
                  | image_url: width: 220
                  | image_tag:
                    class: 'header-logo-image',
                    widths: '120,180,220',
                    sizes: '180px',
                    loading: 'lazy',
                    alt: shop.name
                }}
              {%- else -%}
                <span class="font-serif text-h5">{{ shop.name }}</span>
              {%- endif -%}
            </a>
            <div class="mobile-menu-actions">
              <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="{{ 'general.cart' | t }}" data-open-cart>
                {% render 'icon', name: 'cart' %}
              </a>
              <button type="button" class="icon-btn" aria-label="{{ 'general.search' | t }}" data-open-search>
                {% render 'icon', name: 'search' %}
              </button>
              <button type="button" class="icon-btn" aria-label="{{ 'accessibility.close' | t }}" data-dialog-close>
                {% render 'icon', name: 'hamburger' %}
              </button>
            </div>
          </div>

          <div class="mobile-menu-body">
            <div class="mobile-panels-track">
              <div class="mobile-panel mobile-panel--main">
                <nav class="mobile-nav-links" aria-label="{{ 'general.mobile_navigation' | t }}">
                  {%- for link in linklists[main_menu].links -%}
                    {%- if forloop.last -%}
                      <a href="{{ routes.all_products_collection_url }}" class="mobile-nav-link">
                        {{- 'general.wishlist' | t -}}
                      </a>
                    {%- endif -%}
                    {%- if link.links.size > 0 -%}
                      <button
                        type="button"
                        class="mobile-nav-trigger"
                        data-mobile-submenu-trigger="{{ link.handle | default: link.title | handleize }}"
                        aria-controls="MobilePanel-{{ section.id }}-{{ link.handle | default: link.title | handleize }}"
                        aria-expanded="false"
                      >
                        <span>{{ link.title }}</span>
                        {% render 'icon', name: 'chevron-right' %}
                      </button>
                    {%- else -%}
                      <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
                    {%- endif -%}
                  {%- endfor -%}
                </nav>

                <div class="mobile-menu-footer">
                  <a href="{{ account_url }}" class="btn-outline full-width-btn">{{ 'customers.login.title' | t }}</a>
                  <a href="#FooterNewsletterForm" class="btn-outline full-width-btn" data-dialog-close>
                    {{- 'newsletter.heading' | t -}}
                  </a>
                  <div class="mobile-menu-meta">
                    <div class="mobile-menu-social">
                      {%- if settings.social_instagram != blank -%}
                        <a
                          href="{{ settings.social_instagram }}"
                          aria-label="{{ 'social.instagram' | t }}"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {%- render 'icon', name: 'instagram' -%}
                        </a>
                      {%- endif -%}
                      {%- if settings.social_facebook != blank -%}
                        <a
                          href="{{ settings.social_facebook }}"
                          aria-label="{{ 'social.facebook' | t }}"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {%- render 'icon', name: 'facebook' -%}
                        </a>
                      {%- endif -%}
                      {%- if settings.social_tiktok != blank -%}
                        <a
                          href="{{ settings.social_tiktok }}"
                          aria-label="{{ 'social.tiktok' | t }}"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {%- render 'icon', name: 'tiktok' -%}
                        </a>
                      {%- endif -%}
                      {%- if settings.social_pinterest != blank -%}
                        <a
                          href="{{ settings.social_pinterest }}"
                          aria-label="{{ 'social.pinterest' | t }}"
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          {%- render 'icon', name: 'pinterest' -%}
                        </a>
                      {%- endif -%}
                    </div>
                    <div class="mobile-menu-currency">
                      {% render 'localization-form' %}
                    </div>
                  </div>
                </div>
              </div>

              {%- for link in linklists[main_menu].links -%}
                {%- if link.links.size > 0 -%}
                  <div
                    id="MobilePanel-{{ section.id }}-{{ link.handle | default: link.title | handleize }}"
                    class="mobile-panel mobile-panel--sub"
                    data-mobile-panel="{{ link.handle | default: link.title | handleize }}"
                    aria-hidden="true"
                  >
                    <div class="sub-nav-bar">
                      <button
                        type="button"
                        class="icon-btn"
                        aria-label="{{ 'accessibility.back' | t }}"
                        data-mobile-back
                      >
                        {% render 'icon', name: 'chevron-left' %}
                      </button>
                      <span class="sub-nav-label">{{ link.title }}</span>
                      <button
                        type="button"
                        class="icon-btn"
                        aria-label="{{ 'accessibility.close' | t }}"
                        data-dialog-close
                      >
                        {% render 'icon', name: 'close' %}
                      </button>
                    </div>
                    <div class="mobile-shop-groups">
                      {%- for child_link in link.links -%}
                        <div class="mobile-shop-group">
                          <h3>{{ child_link.title }}</h3>
                          {%- if child_link.links.size > 0 -%}
                            {%- for grandchild in child_link.links -%}
                              <a href="{{ grandchild.url }}">{{ grandchild.title }}</a>
                            {%- endfor -%}
                          {%- else -%}
                            <a href="{{ child_link.url }}">{{ child_link.title }}</a>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </dialog>
    </mobile-menu>
  </header>
</header-component>

{% stylesheet %}
  .header-shell {
    position: sticky;
    top: var(--announcement-height);
    z-index: var(--z-header);
    display: block;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), background-color 0.3s ease;
  }

  .header-shell.is-sticky {
    position: fixed;
    width: 100%;
    top: 0;
    transform: translateY(0);
  }

  .header-shell.is-hidden {
    transform: translateY(calc(-100% - var(--announcement-height)));
  }

  .header-shell--transparent .site-header {
    background: transparent;
  }

  .site-header {
    background: var(--color-background);
    color: var(--color-foreground);
  }

  .header-top {
    padding: 32px var(--gutter) 8px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    justify-content: flex-end;
  }

  .header-nav-list {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding: 1.25rem 0 2rem;
  }

  .logo-long {
    display: inline-flex;
  }

  .logo-symbol,
  .mobile-only-inline {
    display: none;
  }

  .desktop-only-block {
    display: block;
  }

  .header-logo-image {
    width: auto;
    height: var(--logo-height);
    max-width: min(18rem, 100%);
    object-fit: contain;
  }

  .header-action {
    position: relative;
  }

  .header-cart-badge {
    position: absolute;
    top: 0.15rem;
    right: 0.15rem;
    min-width: 1.125rem;
    height: 1.125rem;
    padding: 0 0.25rem;
    border-radius: 999px;
    background: var(--color-secondary-bg);
    color: var(--color-foreground);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-micro);
    line-height: 1;
  }

  .header-cart-badge.is-hidden {
    display: none;
  }

  .header-bottom {
  }

  .header-nav {
    position: relative;
  }

  .header-nav-item {
    display: flex;
    align-items: center;
  }

  .header-nav-link {
    font-size: var(--text-small);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .mobile-nav-link,
  .mobile-nav-trigger {
    font-size: var(--text-body);
    line-height: 1.25;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
  }

  .sub-nav-label {
    flex: 1;
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-body);
    line-height: 1.25;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--color-slate);
  }

  .header-nav-link {
    padding: 0.35rem 0;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .header-nav-link:hover,
  .header-nav-link.is-active {
    border-bottom-color: currentColor;
  }

  .has-mega-menu:hover .mega-menu,
  .has-mega-menu.is-menu-open .mega-menu,
  .has-mega-menu:focus-within .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
    transition: opacity 0.25s ease, visibility 0s linear;
  }

  .mega-menu {
    position: absolute;
    left: 50%;
    top: 100%;
    width: 95vw;
    transform: translate(-50%, 0);
    opacity: 0;
    visibility: hidden;
    /* Delay close by 250ms so cursor can traverse gap to dropdown */
    transition: opacity 0.2s ease 0.05s, visibility 0s linear 0.25s;
    background: var(--color-background);
    z-index: var(--z-overlay);
  }

  .mega-menu-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 22rem;
    gap: 3rem;
    padding: 2.5rem var(--gutter);
    max-width: var(--page-width, 1440px);
    margin: 0 auto;
  }

  .mega-menu-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .mega-menu-col-title {
    display: block;
    padding-bottom: 0.625rem;
    margin-bottom: 1rem;
    color: var(--color-foreground);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-micro);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .mega-menu-links {
    display: grid;
    gap: 0.625rem;
  }

  .mega-menu-links a {
    display: inline-flex;
    font-size: var(--text-small);
    color: var(--color-foreground);
    letter-spacing: 0.02em;
  }

  .mega-menu-links a:hover {
    color: var(--color-muted);
  }

  .mega-menu-featured {
    position: relative;
    overflow: hidden;
    min-height: 20rem;
    border-radius: 2px;
  }

  .mega-menu-featured-link {
    display: block;
    height: 100%;
  }

  .mega-menu-featured-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .search-dialog,
  .mobile-menu-dialog {
    width: min(100vw, 100%);
    max-width: 100vw;
    max-height: 100vh;
    border: 0;
    margin: 0;
    padding: 0;
    background: transparent;
    color: inherit;
  }

  .mobile-menu-dialog {
    margin-top: calc(var(--announcement-height) + 2px);
    max-height: calc(100vh - var(--announcement-height));
  }

  .search-dialog::backdrop,
  .mobile-menu-dialog::backdrop {
    background: rgba(45, 43, 39, 0.45);
  }

  .mobile-menu-dialog::backdrop {
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent var(--announcement-height),
      rgba(45, 43, 39, 0.45) var(--announcement-height)
    );
  }

  .search-dialog {
    min-height: 100svh;
  }

  .search-inner {
    padding-top: calc(var(--announcement-height) + 2rem);
    padding-bottom: 2rem;
  }

  .search-form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .search-input {
    width: 100%;
    border: 0;
    background: transparent;
    padding: 0;
    font-size: var(--text-body-large);
    color: var(--color-foreground);
  }

  .search-results {
    display: grid;
    gap: 1.5rem;
    padding-top: 1.5rem;
  }

  .search-results-products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 1rem;
  }

  .search-result-card {
    display: grid;
    gap: 0.75rem;
  }

  .search-result-card img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .search-results-links ul {
    display: grid;
    gap: 0.5rem;
  }

  .search-results-empty {
    margin: 0;
    font-size: var(--text-body);
  }

  .mobile-menu-content {
    width: min(100vw, 28rem);
    min-height: calc(100svh - var(--announcement-height));
    margin-left: auto;
    background: var(--color-background);
    display: flex;
    flex-direction: column;
    padding: 0 var(--gutter) calc(var(--space-lg) + env(safe-area-inset-bottom, 0px));
  }

  .mobile-menu-top,
  .mobile-menu-actions,
  .sub-nav-bar,
  .mobile-menu-meta,
  .mobile-menu-social {
    display: flex;
    align-items: center;
  }

  .mobile-menu-top {
    justify-content: space-between;
    gap: var(--space-md);
    border-bottom: 1px solid var(--border-light);
    margin: 0;
    padding: 16px 0 16px;
  }

  .mobile-menu-brand {
    display: inline-flex;
    flex-shrink: 0;
    height: 22px;
  }

  .mobile-menu-brand .header-logo-image {
    height: 16px;
    width: auto;
    max-width: none;
  }

  .header-scrolled .header-centre,
  .header-scrolled .header-logo-image {
    height: 64px;
  }

  .header-scrolled .header-top {
    padding: 4px 0;
  }

  .sub-nav-bar {
    justify-content: space-between;
    gap: 1rem;
    min-height: 48px;
  }

  .sub-nav-bar button[aria-label='Back'] {
    margin-left: -16px;
  }

  .mobile-menu-actions {
    gap: 0;
  }

  .mobile-menu-actions .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .mobile-menu-actions .icon-btn svg {
    width: 20px;
    height: 20px;
  }

  .mobile-menu-social {
    gap: var(--space-sm);
  }

  .mobile-menu-body {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    position: relative;
  }

  .mobile-panels-track {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 200%;
    display: flex;
    flex-direction: row;
    transition: transform 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .mobile-panels-track.submenu-active {
    transform: translateX(-50%);
  }

  .mobile-panel {
    width: 50%;
    flex-shrink: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    display: flex;
    flex-direction: column;
    padding-bottom: calc(var(--space-lg) + env(safe-area-inset-bottom, 0px));
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .mobile-shop-groups {
    display: grid;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
  }

  .mobile-nav-link,
  .mobile-nav-trigger {
    justify-content: space-between;
    padding: 0;
  }

  .mobile-nav-trigger {
    display: flex;
    align-items: center;
    width: 100%;
    color: var(--color-slate);
  }

  .mobile-menu-footer {
    margin-top: auto;
    padding-top: var(--space-xl);
    display: grid;
    gap: var(--space-md);
  }

  .mobile-menu-footer .full-width-btn {
    max-width: none;
    min-height: 36px;
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-small);
    letter-spacing: 0.14em;
    border-color: var(--border-dark);
  }

  .mobile-menu-meta {
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .mobile-menu-social a {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu-social svg {
    width: 20px;
    height: 20px;
  }

  .mobile-menu-currency {
    width: 98px;
    flex-shrink: 0;
  }

  .mobile-shop-group {
    display: grid;
    gap: 0.75rem;
  }

  .mobile-shop-group h3 {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-mocha);
  }

  .mobile-shop-group a {
    font-size: var(--text-small);
    color: var(--color-mocha);
    font-weight: 300;
  }

  .desktop-only-inline {
    display: inline-flex;
  }

  /* ── Desktop sticky: pin header at top, announcement bar scrolls away ── */
  @media screen and (min-width: 769px) {
    .header-shell {
      top: 0;
    }

    /* Neutralise JS-driven classes so header never hides or changes appearance */
    .header-shell.is-sticky {
      position: sticky;
      transform: none;
    }

    .header-shell.is-hidden {
      transform: none;
    }
  }

  @media screen and (max-width: 989px) {
    .desktop-only-inline,
    .desktop-only-block {
      display: none;
    }

    .mobile-only-inline {
      display: inline-flex;
    }

    .logo-long {
      display: inline-flex;
    }

    .logo-symbol {
      display: none;
    }

    .site-header {
      border-bottom: none;
    }

    .header-top {
      display: flex;
      align-items: center;
      gap: 0;
      padding-top: 16px;
      padding-bottom: 16px;
    }

    .header-centre {
      order: 1;
      text-align: left;
      padding: 0;
      margin-right: auto;
    }

    .header-left {
      flex-direction: row-reverse;
      gap: 0;
      order: 2;
    }

    .header-right {
      gap: 0;
      order: 3;
    }

    .header-shell.is-sticky .logo-long {
      display: none;
    }

    .header-shell.is-sticky .logo-symbol {
      display: inline-flex;
    }

    .mobile-menu-content {
      width: min(100vw, 100%);
    }

    .search-inner {
      padding-top: calc(var(--announcement-height) + 1rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo override"
    },
    {
      "type": "image_picker",
      "id": "logo_mobile",
      "label": "Mobile logo override"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "sticky_header",
      "label": "Sticky header behaviour",
      "default": "always",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "always", "label": "Always" },
        { "value": "scroll-up", "label": "Show on scroll up" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_transparent",
      "label": "Enable transparent header on the homepage",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "mega_menu_featured_image",
      "label": "Mega menu featured image"
    },
    {
      "type": "url",
      "id": "mega_menu_featured_link",
      "label": "Mega menu featured link"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
