{%- liquid
  assign footer_brand_name = 'SCENTS BY SARA'
  assign instagram_url = settings.social_instagram | default: 'https://instagram.com'
  assign facebook_url = settings.social_facebook | default: 'https://facebook.com'
  assign tiktok_url = settings.social_tiktok | default: 'https://tiktok.com'
  assign pinterest_url = settings.social_pinterest | default: 'https://pinterest.com'
  assign menu_1_mobile_heading = section.settings.menu_1_heading | replace: ' ALL', ''
  assign menu_1_desktop_suffix = section.settings.menu_1_heading | remove_first: menu_1_mobile_heading
  assign menu_2_mobile_heading = section.settings.menu_2_heading | replace: ' US', ''
  assign menu_2_desktop_suffix = section.settings.menu_2_heading | remove_first: menu_2_mobile_heading
-%}

<footer class="footer-section color-{{ section.settings.color_scheme }}">
  <div class="footer-section__inner container">
    <div class="footer-section__grid">
      <div class="footer-section__newsletter">
        <h2 class="footer-section__heading font-serif">
          {{ section.settings.newsletter_heading | escape }}
        </h2>

        {%- if section.settings.newsletter_text != blank -%}
          <div class="footer-section__newsletter-text text-body">
            {{ section.settings.newsletter_text }}
          </div>
        {%- endif -%}

        {%- form 'customer', id: 'FooterNewsletterForm', class: 'footer-section__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}
            <p class="footer-section__message" role="status">
              {{ 'newsletter.success' | t }}
            </p>
          {%- endif -%}

          {{ form.errors | default_errors }}

          <div class="footer-section__newsletter-fields">
            <label class="footer-section__label" for="FooterNewsletterEmail">
              {{ 'newsletter.email_label' | t }}
            </label>
            <input
              id="FooterNewsletterEmail"
              class="footer-section__input"
              type="email"
              name="contact[email]"
              autocomplete="email"
              placeholder="{{ 'newsletter.email_placeholder' | t }}"
              required
            >
            <button type="submit" class="footer-section__button btn-solid">
              {{ 'newsletter.subscribe' | t }}
            </button>
          </div>
        {%- endform -%}

        <div class="footer-section__socials" aria-label="{{ 'general.social_media_links' | t }}">
          <a
            href="{{ instagram_url }}"
            class="footer-section__social"
            aria-label="{{ 'social.instagram' | t }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="{{ 'footer-icon-instagram.svg' | asset_url }}"
              alt=""
              aria-hidden="true"
              loading="lazy"
              width="39"
              height="39"
            >
          </a>
          <a
            href="{{ facebook_url }}"
            class="footer-section__social"
            aria-label="{{ 'social.facebook' | t }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="{{ 'footer-icon-facebook.svg' | asset_url }}"
              alt=""
              aria-hidden="true"
              loading="lazy"
              width="39"
              height="39"
            >
          </a>
          <a
            href="{{ tiktok_url }}"
            class="footer-section__social"
            aria-label="{{ 'social.tiktok' | t }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="{{ 'footer-icon-tiktok.svg' | asset_url }}"
              alt=""
              aria-hidden="true"
              loading="lazy"
              width="39"
              height="39"
            >
          </a>
          <a
            href="{{ pinterest_url }}"
            class="footer-section__social"
            aria-label="{{ 'social.pinterest' | t }}"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="{{ 'footer-icon-pinterest.svg' | asset_url }}"
              alt=""
              aria-hidden="true"
              loading="lazy"
              width="39"
              height="39"
            >
          </a>
        </div>
      </div>

      <details class="footer-section__menu" data-accordion data-accordion-group="footer">
        <summary class="footer-section__menu-title" aria-label="{{ section.settings.menu_1_heading | escape }}">
          <span>
            {{ menu_1_mobile_heading }}
            {%- if menu_1_desktop_suffix != blank -%}
              <span class="footer-section__menu-suffix">{{ menu_1_desktop_suffix }}</span>
            {%- endif -%}
          </span>
          <span class="footer-section__menu-icon" aria-hidden="true">+</span>
        </summary>
        <div class="footer-section__menu-panel">
          <ul class="footer-section__menu-list" role="list">
            {%- if section.settings.menu_1 != blank and section.settings.menu_1.links.size > 0 -%}
              {%- for link in section.settings.menu_1.links -%}
                <li class="footer-section__menu-item">
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            {%- else -%}
              <li class="footer-section__menu-item footer-section__menu-item--empty">
                <span>{{ 'general.menu_not_assigned' | t }}</span>
              </li>
            {%- endif -%}
          </ul>
        </div>
      </details>

      <details class="footer-section__menu" data-accordion data-accordion-group="footer">
        <summary class="footer-section__menu-title" aria-label="{{ section.settings.menu_2_heading | escape }}">
          <span>
            {{ menu_2_mobile_heading }}
            {%- if menu_2_desktop_suffix != blank -%}
              <span class="footer-section__menu-suffix">{{ menu_2_desktop_suffix }}</span>
            {%- endif -%}
          </span>
          <span class="footer-section__menu-icon" aria-hidden="true">+</span>
        </summary>
        <div class="footer-section__menu-panel">
          <ul class="footer-section__menu-list" role="list">
            {%- if section.settings.menu_2 != blank and section.settings.menu_2.links.size > 0 -%}
              {%- for link in section.settings.menu_2.links -%}
                <li class="footer-section__menu-item">
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            {%- else -%}
              <li class="footer-section__menu-item footer-section__menu-item--empty">
                <span>{{ 'general.menu_not_assigned' | t }}</span>
              </li>
            {%- endif -%}
          </ul>
        </div>
      </details>

      <details class="footer-section__menu" data-accordion data-accordion-group="footer">
        <summary class="footer-section__menu-title" aria-label="{{ section.settings.menu_3_heading | escape }}">
          <span>{{ section.settings.menu_3_heading }}</span>
          <span class="footer-section__menu-icon" aria-hidden="true">+</span>
        </summary>
        <div class="footer-section__menu-panel">
          <ul class="footer-section__menu-list" role="list">
            {%- if section.settings.menu_3 != blank and section.settings.menu_3.links.size > 0 -%}
              {%- for link in section.settings.menu_3.links -%}
                <li class="footer-section__menu-item">
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            {%- else -%}
              <li class="footer-section__menu-item footer-section__menu-item--empty">
                <span>{{ 'general.menu_not_assigned' | t }}</span>
              </li>
            {%- endif -%}
          </ul>
        </div>
      </details>

      <details class="footer-section__menu" data-accordion data-accordion-group="footer">
        <summary class="footer-section__menu-title" aria-label="{{ section.settings.menu_4_heading | escape }}">
          <span>{{ section.settings.menu_4_heading }}</span>
          <span class="footer-section__menu-icon" aria-hidden="true">+</span>
        </summary>
        <div class="footer-section__menu-panel">
          <ul class="footer-section__menu-list" role="list">
            {%- if section.settings.menu_4 != blank and section.settings.menu_4.links.size > 0 -%}
              {%- for link in section.settings.menu_4.links -%}
                <li class="footer-section__menu-item">
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            {%- else -%}
              <li class="footer-section__menu-item footer-section__menu-item--empty">
                <span>{{ 'general.menu_not_assigned' | t }}</span>
              </li>
            {%- endif -%}
          </ul>
        </div>
      </details>
    </div>

    <div class="footer-section__divider"></div>

    <div class="footer-section__bottom">
      <div class="footer-section__brand">
        <a
          href="{{ routes.root_url }}"
          class="footer-section__brand-link footer-section__brand-link--desktop"
          aria-label="{{ footer_brand_name }}"
        >
          <img
            src="{{ 'footer-logo.svg' | asset_url }}"
            alt="{{ footer_brand_name }}"
            class="footer-section__brand-logo footer-section__brand-logo--desktop"
            loading="lazy"
            width="300"
            height="53"
          >
        </a>

        <a
          href="{{ routes.root_url }}"
          class="footer-section__brand-link footer-section__brand-link--mobile"
          aria-label="{{ footer_brand_name }}"
        >
          <img
            src="{{ 'footer-logo-symbol.svg' | asset_url }}"
            alt="{{ footer_brand_name }}"
            class="footer-section__brand-logo footer-section__brand-logo--mobile"
            loading="lazy"
            width="143"
            height="143"
          >
        </a>

        <p class="footer-section__copyright">
          &copy; {{ 'now' | date: '%Y' }}
          {{ footer_brand_name }}. {{ 'footer.rights_reserved' | t }}
        </p>
      </div>

      {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
        <div class="footer-section__payments" aria-label="{{ 'general.payment_methods' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <script type="module" src="{{ 'accordion.js' | asset_url }}"></script>

  <script>
    (function () {
      var menus = document.querySelectorAll('.footer-section__menu[data-accordion]');
      var mq = window.matchMedia('(min-width: 768px)');

      function syncOpen(isExpanded) {
        menus.forEach(function (el) {
          if (isExpanded) {
            el.setAttribute('open', '');
          } else if (!el.hasAttribute('data-accordion-open')) {
            el.removeAttribute('open');
          }
        });
      }

      syncOpen(mq.matches);
      mq.addEventListener('change', function (e) {
        syncOpen(e.matches);
      });
      mq.addEventListener('change', function (e) {
        syncOpen(e.matches);
      });
    })();
  </script>
</footer>

{% stylesheet %}
  .footer-section {
    padding-block: 60px;
    background-color: var(--color-secondary-bg);
    color: var(--color-foreground);
  }

  .footer-section__grid {
    display: grid;
    grid-template-columns: 2fr 0.8fr 0.8fr 0.8fr 1.2fr;
    gap: 80px;
    align-items: start;
  }
  .footer-section__newsletter h2 {
    padding-bottom: var(--space-md);
    font-size: var(--text-heading-extra);
  }
  .footer-section__newsletter h2 {
    padding-bottom: var(--space-md);
    font-size: var(--text-heading-extra);
  }

  .footer-section__newsletter-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    width: 100%;
    gap: var(--space-lg);
    width: 100%;
    align-items: flex-start;
  }

  .footer-section__newsletter-fields label {
    display: none;
  }

  .footer-section__newsletter-fields label {
    display: none;
  }

  .footer-section__input {
    width: 100%;
    min-height: 48px;
    padding: 0 20px;
    border: 1px solid var(--color-taupe);
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    letter-spacing: 0.05em;
  }

  .footer-section__input::placeholder {
    color: var(--color-foreground);
    opacity: 0.6;
  }

  .footer-section__button {
    width: 182px;
    width: 182px;
    padding-inline: 24px;
  }

  .footer-section__socials {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    margin-top: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .footer-section__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    color: var(--color-foreground);
  }

  .footer-section__social img {
    width: 38px;
    height: 38px;
    width: 38px;
    height: 38px;
    display: block;
  }

  .footer-section__menu {
    min-width: 0;
  }

  .footer-section__menu-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    width: 100%;
    padding: 0 0 var(--space-md);
    padding: 0 0 var(--space-md);
    border-bottom: 1px solid var(--color-foreground);
    font-family: var(--font-serif);
    font-size: var(--text-h4);
    font-size: var(--text-h4);
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--color-foreground);
    text-transform: uppercase;
  }

  .footer-section__menu-title::-webkit-details-marker {
    display: none;
  }

  .footer-section__menu-icon {
    display: none;
    font-family: var(--font-sans);
    font-size: var(--text-body-large);
    font-weight: 300;
    line-height: 1;
  }

  .footer-section__menu-suffix {
    display: inline;
  }

  .footer-section__menu-panel {
    display: block;
    padding-top: 28px;
  }

  .footer-section__menu-list {
    display: grid;
    gap: 16px;
    list-style: none;
  }

  .footer-section__menu-item a,
  .footer-section__menu-item span {
    font-size: var(--text-body-large);
    font-size: var(--text-body-large);
    font-weight: 300;
    color: var(--color-foreground);
  }

  .footer-section__divider {
    margin-block: 80px 48px;
    border-top: 1px solid color-mix(in srgb, var(--color-foreground) 20%, transparent);
  }

  .footer-section__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-lg);
  }

  .footer-section__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    min-width: 0;
  }

  .footer-section__brand-link {
    display: inline-flex;
    align-items: center;
  }

  .footer-section__brand-link--desktop {
    width: 300px;
    max-width: 100%;
  }

  .footer-section__brand-logo {
    display: block;
    width: 100%;
    height: auto;
  }

  .footer-section__brand-link--mobile,
  .footer-section__brand-logo--mobile {
    display: none;
  }

  .footer-section__brand-logo--mobile {
    width: 60px;
  }

  .footer-section__copyright {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-xsmall);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .footer-section__payments {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-section__payments svg {
    width: auto;
    height: 28px;
  }

  @media (min-width: 768px) and (max-width: 1099px) {
    .footer-section {
      padding-block: 48px 40px;
    }

    .footer-section__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 48px 36px;
    }

    .footer-section__newsletter {
      grid-column: 1 / -1;
    }

    .footer-section__heading {
      margin-bottom: 18px;
    }

    .footer-section__socials {
      margin-top: 36px;
    }

    .footer-section__divider {
      margin-block: 56px 36px;
    }

    .footer-section__brand-link--desktop {
      width: 300px;
    }

    .footer-section__payments {
      max-width: 320px;
    }
  }

  @media (min-width: 768px) {
    .footer-section__menu-panel {
      display: block !important;
    }

    .footer-section__menu-title {
      pointer-events: none;
    }
  }

  @media (max-width: 767px) {
    .footer-section {
      padding-block: 32px 24px;
    }

    .footer-section__inner.container {
      padding-inline: 20px;
    }

    .footer-section__grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .footer-section__newsletter {
      margin-bottom: 22px;
    }

    .footer-section__heading {
      margin-bottom: 18px;
      font-size: var(--text-h6);
      letter-spacing: -0.01em;
    }

    .footer-section__newsletter-fields {
      justify-items: stretch;
    }

    .footer-section__input {
      min-height: 42px;
      padding-inline: 14px;
      font-size: var(--text-micro);
      letter-spacing: 0.18em;
    }

    .footer-section__button {
      width: 118px;
      min-height: 30px;
      padding: 9px 16px;
      font-size: var(--text-micro);
      letter-spacing: 0.1em;
    }

    .footer-section__socials {
      gap: 12px;
      margin-top: 24px;
      margin-bottom: 18px;
    }

    .footer-section__social {
      width: 20px;
      height: 20px;
    }

    .footer-section__social img {
      width: 20px;
      height: 20px;
    }

    .footer-section__menu {
      width: 100%;
      border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 20%, transparent);
    }

    .footer-section__menu-title {
      padding: 18px 0;
      border-bottom: 0;
      font-family: var(--font-serif);
      font-size: var(--text-small);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      cursor: pointer;
    }

    .footer-section__menu-suffix {
      display: none;
    }

    .footer-section__menu-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 16px;
      font-size: var(--text-body);
    }

    .footer-section__menu-panel {
      display: none;
      padding: 0 0 18px;
    }

    .footer-section__menu[open] .footer-section__menu-panel {
      display: block;
    }

    .footer-section__menu[open] .footer-section__menu-icon {
      transform: rotate(45deg);
    }

    .footer-section__menu-list {
      gap: 12px;
    }

    .footer-section__menu-item a,
    .footer-section__menu-item span {
      font-size: var(--text-small);
    }

    .footer-section__divider {
      margin-block: 28px 20px;
    }

    .footer-section__bottom {
      margin-top: 0;
    }

    .footer-section__payments {
      display: none;
    }

    .footer-section__brand {
      width: 100%;
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 20px;
    }

    .footer-section__brand-link--desktop,
    .footer-section__brand-logo--desktop {
      display: none;
    }

    .footer-section__brand-link--mobile,
    .footer-section__brand-logo--mobile {
      display: inline-flex;
    }

    .footer-section__copyright {
      max-width: 350px;
      padding-bottom: 10px;
      font-size: 9px;
      line-height: 1.4;
      text-align: right;
      opacity: 0.55;
    }
  }

  @media screen and (max-width: 480px){
    .footer-section__newsletter h2 {
      font-size: var(--text-h4);
      padding-bottom: 0;
    }

    .footer-section__divider {
      display: none;
    }

    .footer-section__brand {
      margin-top: var(--space-md);
    }

    .footer-section__copyright {
      max-width: 300px;
      letter-spacing: 18%;
    }
  }
{% endstylesheet %}

