{%- liquid
  assign products_to_show = section.settings.products_to_show | default: 4
  assign recommendations_url = routes.product_recommendations_url | append: '?product_id=' | append: product.id | append: '&limit=' | append: products_to_show | append: '&section_id=' | append: section.id
  assign card_layout = section.settings.card_layout | default: 'compact'
-%}

<section
  id="ProductRecommendations-{{ section.id }}"
  class="section-block best-sellers product-recommendations{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}"
  data-product-recommendations
  data-url="{{ recommendations_url }}"
>
  <div class="container product-recommendations__container">
    {%- if section.settings.heading != blank -%}
      <header class="product-recommendations__header">
        <h2 class="section-title font-serif text-h3">{{ section.settings.heading | escape }}</h2>
      </header>
    {%- endif -%}

    {%- if recommendations.performed? and recommendations.products_count > 0 -%}
      <div class="product-grid grid-cols-4 product-recommendations__grid" data-product-recommendations-content>
        {%- liquid
          assign shown_count = 0
          assign rendered_product_ids = '|' | append: product.id | append: '|'
        -%}
        {%- for product in recommendations.products limit: products_to_show -%}
          {%- assign rendered_product_ids = rendered_product_ids | append: product.id | append: '|' -%}
          {%- assign shown_count = shown_count | plus: 1 -%}
          {% render 'product-card',
            product: product,
            card_layout: card_layout,
            show_secondary_image: true,
            show_swatches: true,
            show_quick_add: false,
            show_wishlist: true
          %}
        {%- endfor -%}

        {%- if shown_count < products_to_show -%}
          {%- for fallback_product in collections.all.products limit: 12 -%}
            {%- if shown_count >= products_to_show -%}
              {%- break -%}
            {%- endif -%}

            {%- capture fallback_marker -%}|{{ fallback_product.id }}|{%- endcapture -%}
            {%- unless rendered_product_ids contains fallback_marker -%}
              {%- assign rendered_product_ids = rendered_product_ids | append: fallback_product.id | append: '|' -%}
              {%- assign shown_count = shown_count | plus: 1 -%}
              {% render 'product-card',
                product: fallback_product,
                card_layout: card_layout,
                show_secondary_image: true,
                show_swatches: true,
                show_quick_add: false,
                show_wishlist: true
              %}
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- elsif recommendations.performed? -%}
      <div class="product-recommendations__empty" role="status">
        No related products are available right now.
      </div>
    {%- else -%}
      <div class="product-recommendations__loading" data-product-recommendations-status aria-live="polite">
        Finding related products...
      </div>
      <div class="product-grid grid-cols-4 product-recommendations__grid" data-product-recommendations-content hidden></div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .product-recommendations {
    padding-top: var(--space-section);
  }

  .product-recommendations__header {
    margin-bottom: clamp(2rem, 3vw, 2.75rem);
    text-align: center;
  }

  .product-recommendations__container {
    text-align: center;
  }

  .product-recommendations__grid {
    margin-top: 0;
    gap: 32px;
  }

  .product-recommendations__grid.product-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .product-recommendations .product-card {
    min-width: auto;
    text-align: left;
  }

  .product-recommendations .product-card__options {
    justify-content: flex-start;
    gap: 8px;
  }

  .product-recommendations .variant-swatches__swatch {
    width: 20px;
    height: 20px;
    border-color: var(--color-background);
    box-shadow: none;
    transform: none;
  }

  .product-recommendations .variant-swatches__swatch.is-active,
  .product-recommendations .variant-swatches__swatch:hover {
    transform: none;
    box-shadow: inset 0 0 0 1px var(--color-background), 0 0 0 1px var(--color-border);
  }

  .product-recommendations .product-card__body {
    margin-bottom: 20px;
    text-align: left;
  }

  .product-recommendations .product-card__copy {
    gap: 4px;
    align-items: flex-start;
  }

  .product-recommendations .product-card__title,
  .product-recommendations .product-card__title a,
  .product-recommendations .product-card__subtitle {
    text-align: left;
  }

  .product-recommendations .product-card .product-price {
    flex-direction: row;
    align-items: baseline;
    justify-content: flex-end;
    gap: 4px;
    text-align: right;
  }

  .product-recommendations .product-card__button {
    margin-top: auto;
  }

  .product-recommendations .product-card__wishlist {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 1;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .product-recommendations .product-card__wishlist svg {
    color: var(--color-muted);
  }

  @media (min-width: 1440px) {
    .product-recommendations__grid.product-grid {
      gap: 32px;
    }
  }

  @media (max-width: 989px) {
    .product-recommendations__grid.product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }
  }

  .product-recommendations__loading,
  .product-recommendations__empty {
    padding-block: var(--space-lg);
    color: var(--color-muted);
    text-align: center;
  }
{% endstylesheet %}

<script type="module">
  const section = document.getElementById('ProductRecommendations-{{ section.id }}');

  if (section && section.dataset.productRecommendationsLoaded !== 'true') {
    section.dataset.productRecommendationsLoaded = 'true';

    const loadRecommendations = async () => {
      const url = section.dataset.url;

      if (!url) {
        return;
      }

      try {
        const response = await fetch(url, { headers: { Accept: 'text/html' } });

        if (!response.ok) {
          throw new Error(`Recommendations request failed: ${response.status}`);
        }

        const html = await response.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const nextSection = doc.querySelector('[data-product-recommendations]');

        if (!nextSection) {
          return;
        }

        section.replaceWith(nextSection);
      } catch (error) {
        const status = section.querySelector('[data-product-recommendations-status]');

        if (status) {
          status.textContent = 'Related products are unavailable right now.';
        }
      }
    };

    queueMicrotask(loadRecommendations);
  }
</script>

{% schema %}
{
  "name": "Product recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOU MAY ALSO LIKE"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "Card layout",
      "default": "compact",
      "options": [
        {
          "value": "stacked",
          "label": "Full / Stacked"
        },
        {
          "value": "shop",
          "label": "Shop / Collection"
        },
        {
          "value": "compact",
          "label": "Compact / Carousel"
        }
      ]
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Add a custom class to the section element for section-specific CSS overrides."
    }
  ],
  "presets": [
    {
      "name": "Product recommendations"
    }
  ]
}
{% endschema %}
