<section class="page-section section-block color-scheme-1">
  <div class="container page-section__inner">
    <header class="page-section__header">
      <h1 class="font-serif text-h1">{{ page.title }}</h1>
    </header>

    <div class="rte page-section__content">
      {{ page.content }}
    </div>
  </div>
</section>

{% stylesheet %}
  .page-section__inner {
    max-width: 56rem;
    display: grid;
    gap: var(--space-lg);
  }

  .page-section__content {
    color: var(--color-foreground);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
