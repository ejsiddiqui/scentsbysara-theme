<section class="search-page section-block color-scheme-1">
  <div class="container search-page__inner">
    <header class="search-page__header">
      <h1 class="font-serif text-h1">{{ 'search.title' | t }}</h1>
      <p class="text-body text-muted">Search products, stories, and pages across Scents by Sara.</p>
    </header>

    <form action="{{ routes.search_url }}" method="get" class="search-page__form" role="search">
      <label for="SearchPageInput" class="visually-hidden">{{ 'search.placeholder' | t }}</label>
      <input
        id="SearchPageInput"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
        class="form-input"
      >
      <button type="submit" class="btn-solid">{{ 'search.submit' | t }}</button>
    </form>

    {% if search.performed %}
      {% paginate search.results by 20 %}
        {% if search.results_count == 0 %}
          <div class="search-page__empty">
            <p>{{ 'search.no_results_html' | t: terms: search.terms }}</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn-outline">CONTINUE SHOPPING</a>
          </div>
        {% else %}
          <p class="search-page__meta text-small text-muted">
            {{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}
          </p>

          <div class="search-results grid-cols-4">
            {% for result in search.results %}
              {% if result.object_type == 'product' %}
                {% render 'product-card',
                  product: result,
                  card_layout: 'shop',
                  show_secondary_image: true,
                  show_swatches: true,
                  show_quick_add: false
                %}
              {% else %}
                {% assign featured_image = result.featured_image | default: result.image %}
                <article class="search-result-card">
                  {% if featured_image %}
                    {% render 'image',
                      image: featured_image,
                      alt: result.title,
                      widths: '320,480,640',
                      sizes: '(min-width: 990px) 25vw, 100vw',
                      loading: 'lazy',
                      class: 'search-result-card__image'
                    %}
                  {% endif %}

                  <div class="search-result-card__body">
                    <span class="eyebrow">{{ result.object_type | upcase }}</span>
                    <h2 class="search-result-card__title">
                      <a href="{{ result.url }}">{{ result.title }}</a>
                    </h2>
                    <p class="text-small text-muted">{{ result.content | strip_html | truncate: 140 }}</p>
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>

          {% render 'pagination', paginate: paginate %}
        {% endif %}
      {% endpaginate %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .search-page__inner {
    display: grid;
    gap: var(--space-lg);
  }

  .search-page__header {
    max-width: 40rem;
  }

  .search-page__form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
  }

  .search-page__meta {
    margin: 0;
  }

  .search-page__empty {
    display: grid;
    gap: 1rem;
    justify-items: start;
  }

  .search-result-card {
    display: grid;
    gap: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-secondary-bg);
  }

  .search-result-card__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .search-result-card__body {
    padding: 1.25rem;
  }

  .search-result-card__title {
    margin: 0.5rem 0;
    font-size: var(--text-h4);
  }

  .search-result-card__title a {
    color: inherit;
    text-decoration: none;
  }

  @media (max-width: 749px) {
    .search-page__form {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
