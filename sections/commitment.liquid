{%- liquid
  assign section_eyebrow = section.settings.eyebrow | default: 'OUR COMMITMENT'
  assign section_heading = section.settings.heading | default: 'INTENTIONAL DESIGN IN SCENT AND FORM.'
  assign image_alt = section.settings.image_alt | default: section_heading
  assign is_product_template = false
  assign lead_text = section.settings.description

  if request.page_type == 'product'
    assign is_product_template = true
  endif

  for block in section.blocks
    if block.type == 'value' and lead_text == blank and block.settings.description != blank
      assign lead_text = block.settings.description
    endif
  endfor
-%}

<section
  id="Commitment-{{ section.id }}"
  class="commitment-section section-block color-{{ section.settings.color_scheme }}{% if is_product_template %} commitment-section--product{% endif %}{% if section.settings.full_width %} commitment-section--full-width{% endif %}"
>
  <div class="container">
    {%- if is_product_template -%}
      <div class="product-commitment-grid">
        <div class="commitment-img-col commitment-section__media">
          {%- if section.settings.image != blank -%}
            {% render 'image',
              class: 'commitment-section__image',
              image: section.settings.image,
              alt: image_alt,
              widths: '600,900,1200,1500',
              sizes: '50vw',
              loading: 'lazy'
            %}
          {%- else -%}
            <img class="commitment-section__image" src="{{ 'our-commitment-left.png' | asset_url }}" alt="{{ image_alt | escape }}" width="1200" height="1200">
          {%- endif -%}
        </div>

        <div class="commitment-content-col commitment-section__content">
          <span class="eyebrow">{{ section_eyebrow | escape }}</span>
          <h2 class="font-serif commitment-section__heading">{{ section_heading | escape }}</h2>

          {%- if lead_text != blank -%}
            <p class="desc">{{ lead_text | escape }}</p>
          {%- endif -%}

          <div class="commitment-list" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'value' and block.settings.title != blank -%}
                <span class="commitment-list-item" role="listitem" {{ block.shopify_attributes }}>
                  {{ block.settings.title | escape }}
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- else -%}
      <div class="commitment-section__layout{% if section.settings.image_position == 'right' %} commitment-section__layout--reverse{% endif %}">
        <div class="commitment-section__media">
          {%- if section.settings.image != blank -%}
            {% render 'image',
              class: 'commitment-section__image',
              image: section.settings.image,
              alt: image_alt,
              widths: '600,900,1200,1500',
              sizes: '(max-width: 989px) 100vw, 50vw',
              loading: 'lazy'
            %}
          {%- else -%}
            <img class="commitment-section__image" src="{{ 'our-commitment-left.png' | asset_url }}" alt="{{ image_alt | escape }}" width="1200" height="1200">
          {%- endif -%}
        </div>

        <div class="commitment-section__content">
          <span class="eyebrow">{{ section_eyebrow | escape }}</span>
          <h2 class="font-serif commitment-section__heading">{{ section_heading | escape }}</h2>

          <div class="commitment-section__items" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'value' -%}
                <article class="commitment-section__item" role="listitem" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    {% render 'image',
                      class: 'commitment-section__item-icon',
                      image: block.settings.icon,
                      alt: block.settings.title,
                      widths: '48,72,96',
                      sizes: '48px',
                      loading: 'lazy'
                    %}
                  {%- endif -%}
                  <h3 class="commitment-section__item-heading">{{ block.settings.title | escape }}</h3>
                  <p class="commitment-section__item-text">{{ block.settings.description | escape | newline_to_br }}</p>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
            <a href="{{ section.settings.button_link }}" class="commitment-section__button btn-outline">
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  #Commitment-{{ section.id }} {
    overflow: clip;
  }

  /* Fix 1 — full-width container option */
  #Commitment-{{ section.id }}.commitment-section--full-width .container {
    width: 100%;
    max-width: 100%;
    padding-inline: 0;
  }

  /* Fix 2 & 7 — equal columns, zero gap */
  #Commitment-{{ section.id }} .commitment-section__layout {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    align-items: center;
  }

  #Commitment-{{ section.id }} .commitment-section__layout--reverse .commitment-section__media {
    order: 2;
  }

  #Commitment-{{ section.id }} .commitment-section__layout--reverse .commitment-section__content {
    order: 1;
  }

  #Commitment-{{ section.id }} .commitment-section__media {
    min-width: 0;
  }

  #Commitment-{{ section.id }} .commitment-section__image,
  #Commitment-{{ section.id }} .commitment-section__placeholder {
    width: 100%;
    aspect-ratio: 0.96;
    object-fit: cover;
  }

  #Commitment-{{ section.id }} .commitment-section__placeholder {
    display: grid;
    place-items: center;
    border: 1px dashed var(--color-border);
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-micro);
  }

  /* Fix 3 — content padding */
  #Commitment-{{ section.id }} .commitment-section__content {
    min-width: 0;
    padding: 0 var(--inner-gutter);
  }

  #Commitment-{{ section.id }} .eyebrow {
    color: var(--color-taupe);
  }

  /* Fix 4 — heading typography + spacing for ::after line */
  #Commitment-{{ section.id }} .commitment-section__heading {
    max-width: none;
    font-size: var(--text-h1);
    line-height: 1.1;
    color: var(--color-muted);
    text-transform: uppercase;
    position: relative;
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  /* Fix 5 — decorative line below heading */
  #Commitment-{{ section.id }} .commitment-section__heading:after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 190px;
    height: 1px;
    background-color: var(--color-taupe);
  }

  #Commitment-{{ section.id }} .commitment-section__items {
    display: grid;
    gap: clamp(1.25rem, 2vw, 2rem);
  }

  #Commitment-{{ section.id }} .commitment-section__item {
    display: grid;
    gap: 0.5rem;
    max-width: 42rem;
  }

  #Commitment-{{ section.id }} .commitment-section__item-icon {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
  }

  /* Fix 6 — item heading sans font + body-large size */
  #Commitment-{{ section.id }} .commitment-section__item-heading {
    font-size: var(--text-body-large);
    font-family: var(--font-sans);
  }

  #Commitment-{{ section.id }} .commitment-section__item-text {
    max-width: 36rem;
    font-size: var(--text-body-large);
    color: var(--color-slate);
    font-weight: 300;
    line-height: 1.6;
  }

  #Commitment-{{ section.id }} .commitment-section__button {
    margin-top: clamp(1.75rem, 3vw, 3rem);
  }

  #Commitment-{{ section.id }}.commitment-section--product {
    padding-block: 0;
  }

  #Commitment-{{ section.id }}.commitment-section--product .product-commitment-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: stretch;
    min-height: 960px;
    width: 100vw;
    margin: var(--space-xl) calc(50% - 50vw) 0;
  }

  #Commitment-{{ section.id }}.commitment-section--product .commitment-section__image {
    height: 100%;
    object-fit: cover;
  }

  #Commitment-{{ section.id }}.commitment-section--product .commitment-content-col {
    background: var(--color-secondary-bg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 98px 80px;
  }

  #Commitment-{{ section.id }}.commitment-section--product .commitment-section__heading {
    max-width: none;
    margin-bottom: 36px;
    color: var(--color-muted);
    line-height: 1.08;
  }

  #Commitment-{{ section.id }}.commitment-section--product .desc {
    margin: 0 0 44px;
    max-width: 36rem;
    line-height: 1.35;
  }

  #Commitment-{{ section.id }}.commitment-section--product .commitment-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  #Commitment-{{ section.id }}.commitment-section--product .commitment-list-item {
    color: var(--color-muted);
    font-size: var(--text-h4);
    font-weight: 400;
  }

  @media screen and (max-width: 989px) {
    #Commitment-{{ section.id }} .commitment-section__layout,
    #Commitment-{{ section.id }} .commitment-section__layout--reverse {
      grid-template-columns: 1fr;
    }

    #Commitment-{{ section.id }} .commitment-section__layout--reverse .commitment-section__media,
    #Commitment-{{ section.id }} .commitment-section__layout--reverse .commitment-section__content {
      order: initial;
    }

    #Commitment-{{ section.id }}.commitment-section--product .product-commitment-grid {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    #Commitment-{{ section.id }}.commitment-section--product .commitment-content-col {
      padding: 62px 40px;
    }
  }

  @media screen and (max-width: 749px) {
    #Commitment-{{ section.id }}.commitment-section--product .commitment-content-col {
      padding: 48px 20px;
    }

    #Commitment-{{ section.id }} .commitment-section__heading {
      max-width: none;
    }
  }

  @media screen and (max-width: 480px) {
    #Commitment-{{ section.id }}.section-block {
      padding-block: 0;
      background-color: var(--color-stone);
    }

    #Commitment-{{ section.id }} .commitment-section__content {
      padding: var(--space-lg) var(--gutter);
    }

    #Commitment-{{ section.id }} .commitment-section__heading {
      font-size: var(--text-h4);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Commitment",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR COMMITMENT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "INTENTIONAL DESIGN IN SCENT AND FORM."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every material used by Scents by Sara is chosen for performance, longevity, and environmental consideration."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Matches and candle"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "READ OUR STORY"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Embodied Confidence"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Confidence that is felt rather than performed - creating space to recognise ourselves, our experiences, and how we feel within them."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Commitment",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "title": "Embodied Confidence",
            "description": "Confidence that is felt rather than performed - creating space to recognise ourselves, our experiences, and how we feel within them."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Rooted in Real Stories",
            "description": "Built with its community, not just for it - shaped by lived experience, resilience, and the individuality that defines each person."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Meaningful Gifting",
            "description": "Custom pieces gifted as recognition for self or others - chosen to honour who someone is and the moments that shape them."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Sustainable Craftsmanship",
            "description": "Luxury defined through consideration - for materials, craft, and the environments in which our pieces exist."
          }
        }
      ]
    }
  ]
}
{% endschema %}
