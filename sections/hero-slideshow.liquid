{%- liquid
  assign autoplay = section.settings.autoplay
  assign interval = section.settings.interval | default: 5
  assign transition_type = section.settings.transition_type | default: 'fade'
  assign transition_speed = section.settings.transition_speed | default: 600
  assign drag_enabled = section.settings.drag | default: true
  assign rewind = section.settings.rewind | default: false
  assign slide_count = section.blocks.size
-%}

{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- capture splide_options -%}
{
  "type": {{ transition_type | json }},
  {% if transition_type == 'fade' %}"rewind": true,{% elsif rewind %}"rewind": true,{% endif %}
  "autoplay": {{ autoplay | json }},
  "interval": {{ interval | times: 1000 }},
  "pauseOnHover": true,
  "pauseOnFocus": true,
  "speed": {{ transition_speed }},
  "drag": {{ drag_enabled | json }},
  "arrows": {{ section.settings.show_arrows | json }},
  "pagination": {% if slide_count > 1 %}true{% else %}false{% endif %},
  "classes": {
    "pagination": "splide__pagination hero-dots",
    "page": "splide__pagination__page hero-dot"
  }
}
{%- endcapture -%}

{%- if section.blocks.size > 0 -%}
  <section
    class="splide home-hero full-width color-{{ section.settings.color_scheme | default: 'scheme-1' }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}"
    data-splide='{{ splide_options }}'
    aria-label="{{ section.settings.accessibility_label | default: 'Hero slideshow' | escape }}"
  >
    <div class="splide__track">
      <ul class="splide__list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign slide_loading = 'lazy'
            assign slide_fetchpriority = nil
            if forloop.first
              assign slide_loading = 'eager'
              assign slide_fetchpriority = 'high'
            endif

            assign hero_image = block.settings.image_desktop
            assign fallback_desktop_asset = ''
            assign fallback_mobile_asset = ''

            case forloop.index
              when 1
                assign fallback_desktop_asset = 'desktop-hero-1.png'
                assign fallback_mobile_asset = 'mobile-hero-1.png'
              when 2
                assign fallback_desktop_asset = 'desktop-hero-2.png'
                assign fallback_mobile_asset = 'mobile-hero-2.png'
              when 3
                assign fallback_desktop_asset = 'desktop-hero-3.png'
                assign fallback_mobile_asset = 'mobile-hero-3.png'
            endcase

            if hero_image == blank
              assign hero_image = block.settings.image_mobile
            endif
          -%}

          <li
            class="splide__slide hero-slide"
            {{ block.shopify_attributes }}
          >
            <div class="hero-image">
              {%- if hero_image != blank -%}
                {% render
                  'image',
                  image: hero_image,
                  mobile_image: block.settings.image_mobile,
                  alt: block.settings.heading,
                  sizes: '100vw',
                  loading: slide_loading,
                  fetchpriority: slide_fetchpriority
                %}
              {%- elsif fallback_desktop_asset != blank -%}
                <picture>
                  {%- if fallback_mobile_asset != blank -%}
                    <source media="(max-width: 749px)" srcset="{{ fallback_mobile_asset | asset_url }}">
                  {%- endif -%}
                  <img
                    src="{{ fallback_desktop_asset | asset_url }}"
                    alt="{{ block.settings.heading | escape }}"
                    loading="{{ slide_loading }}"
                    width="1600"
                    height="1800"
                    {% if slide_fetchpriority != blank %}fetchpriority="{{ slide_fetchpriority }}"{% endif %}
                  >
                </picture>
              {%- else -%}
                <div class="hero-placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </div>

            <div class="hero-content container" style="text-align: {{ block.settings.text_alignment }};">
              <div>
                {%- if block.settings.kicker != blank -%}
                  <span class="eyebrow">{{ block.settings.kicker }}</span>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h1 class="font-serif text-hero hero-heading">{{ block.settings.heading }}</h1>
                {%- endif -%}
              </div>

              {%- if block.settings.subheading != blank -%}
                <p class="hero-subtext text-body">{{ block.settings.subheading }}</p>
              {%- endif -%}

              {%- if block.settings.cta_text != blank -%}
                <div class="hero-actions">
                  <a
                    {% if block.settings.cta_link != blank %}
                      href="{{ block.settings.cta_link }}"
                    {% else %}
                      href="{{ routes.all_products_collection_url }}"
                    {% endif %}
                    class="btn-solid"
                  >
                    {{ block.settings.cta_text }}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </section>
{%- else -%}
  <section class="home-hero full-width">
    <div class="hero-slide is-active">
      <div class="hero-placeholder">
        <div class="hero-placeholder-content">
          <span class="eyebrow">Hero slideshow</span>
          <h1 class="font-serif text-hero hero-heading">Add slides in the theme editor</h1>
          <p class="hero-subtext text-body">
            Create one or more slides to match the homepage mockup and configure the content from the customizer.
          </p>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Hero slideshow",
  "settings": [
    {
      "type": "header",
      "content": "Slideshow behaviour"
    },
    {
      "type": "select",
      "id": "transition_type",
      "label": "Transition type",
      "default": "fade",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" },
        { "value": "loop", "label": "Loop (infinite)" }
      ]
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed",
      "min": 300,
      "max": 1200,
      "step": 100,
      "unit": "ms",
      "default": 600
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Slide interval",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "drag",
      "label": "Enable swipe / drag",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rewind",
      "label": "Rewind to first slide",
      "info": "Only applies when transition type is Slide (non-loop).",
      "default": false
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "Hero slideshow"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Add a custom class to the section element for section-specific CSS overrides."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "Scents by Sara"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "THE FEMALE FORM, AS IT IS"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Hand-poured body candles celebrating real bodies and lived experience."
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "CTA text",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text alignment",
          "default": "left",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
