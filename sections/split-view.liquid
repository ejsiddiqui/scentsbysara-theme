{%- liquid
  assign section_eyebrow = section.settings.eyebrow
  assign section_heading = section.settings.heading
  assign image_alt = section.settings.image_alt | default: section_heading
  assign content_background_class = 'bg-secondary'

  if section.settings.content_background == 'primary'
    assign content_background_class = 'bg-primary'
  endif

  assign text_align = section.settings.text_alignment | default: 'left'
  assign content_align_items = 'flex-start'
  if text_align == 'center'
    assign content_align_items = 'center'
  endif

  assign button_align = section.settings.button_alignment | default: 'left'
  assign button_self_align = 'flex-start'
  if button_align == 'center'
    assign button_self_align = 'center'
  elsif button_align == 'right'
    assign button_self_align = 'flex-end'
  endif

  assign heading_max_width = section.settings.heading_max_width | strip

  assign collection_filter = section.settings.collection_filter | strip
  assign skip_section = false
  if collection_filter != blank and collection.handle != collection_filter
    assign skip_section = true
  endif
-%}
{%- unless skip_section -%}

<section
  id="SplitView-{{ section.id }}"
  class="split-view section-block color-{{ section.settings.color_scheme }}{% if section.settings.full_width %} split-view--full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}"
>
  {{ 'section-split-view.css' | asset_url | stylesheet_tag }}

  <div class="{% unless section.settings.full_width %}container{% endunless %}">
    <div class="split-view__grid{% if section.settings.image_position == 'right' %} split-view__grid--reverse{% endif %}">
      <div class="split-view__media">
        {%- if section.settings.image != blank -%}
          {% render 'image',
            class: 'split-view__image',
            image: section.settings.image,
            alt: image_alt,
            loading: 'lazy'
          %}
        {%- elsif section.settings.asset_image != blank -%}
          <img class="split-view__image" src="{{ section.settings.asset_image | asset_url }}" alt="{{ image_alt | escape }}" width="1200" height="1600" loading="lazy">
        {%- else -%}
          <img class="split-view__image" src="{{ 'sara.png' | asset_url }}" alt="{{ image_alt | escape }}" width="1200" height="1600">
        {%- endif -%}
      </div>

      <div class="split-view__content {{ content_background_class }}"{% if text_align != 'left' %} style="text-align: {{ text_align }}; align-items: {{ content_align_items }};"{% endif %}>
        {%- if section_eyebrow != blank -%}
          <span class="eyebrow">{{ section_eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section_heading != blank -%}
          {%- assign h_max_width = heading_max_width -%}
          {%- if h_max_width != blank -%}
            {%- unless h_max_width contains 'px' or h_max_width contains '%' or h_max_width contains 'ch' or h_max_width contains 'rem' or h_max_width contains 'vw' -%}
              {%- assign h_max_width = h_max_width | append: 'px' -%}
            {%- endunless -%}
          {%- endif -%}
          <h2 class="font-serif split-view__heading"{% if h_max_width != blank %} style="max-width: {{ h_max_width }}"{% endif %}>{{ section_heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="container-editorial split-view__body">
            {{ section.settings.body }}
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="split-view__notes">
            {%- for block in section.blocks -%}
              {%- if block.type == 'note' -%}
                <article class="split-view__note" {{ block.shopify_attributes }}>
                  <h3 class="font-serif split-view__note-heading">{{ block.settings.title | escape }}</h3>
                  <p class="split-view__note-text">{{ block.settings.text | escape | newline_to_br }}</p>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: routes.root_url }}" class="{{ section.settings.button_style }} split-view__button" style="align-self: {{ button_self_align }};">
            {{ section.settings.cta_text | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{%- endunless -%}

{% schema %}
{
  "name": "Split view",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "info": "Removes the container — image and content stretch to page edge (max 1920px)",
      "default": false
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "OUR STORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GROUNDED IN RITUAL. EMBODIED IN CONFIDENCE."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Scents By Sara is a female-founded fragrance house rooted in embodied confidence and modern ritual. What began as a personal exploration of scent and form has grown into a brand shaped by lived experience, community, and the power of recognising ourselves as we are.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "asset_image",
      "label": "Theme asset image (filename)",
      "info": "Use a theme asset filename (e.g. our-commitment-left.png) when no shop image is selected."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Founder of Scents by Sara"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "content_background",
      "label": "Content background",
      "options": [
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "primary",
          "label": "Primary"
        }
      ],
      "default": "secondary"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "READ MORE"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "btn-solid",
          "label": "Solid"
        },
        {
          "value": "btn-outline",
          "label": "Outline"
        },
        {
          "value": "btn-underline",
          "label": "Underline"
        }
      ],
      "default": "btn-solid"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "heading_max_width",
      "label": "Heading max-width",
      "info": "Override heading max-width. e.g. 500px, 20ch, none. Leave blank for default (12ch)."
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Add a custom class to the section element for section-specific CSS overrides."
    },
    {
      "type": "text",
      "id": "collection_filter",
      "label": "Show only on collection (handle)",
      "info": "Leave blank to show everywhere. Enter a collection handle (e.g. scar-collection) to restrict to that collection only."
    }
  ],
  "blocks": [
    {
      "type": "note",
      "name": "Note",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Intentional craft"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Every piece is designed to feel considered, personal, and quietly luxurious."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split view",
      "blocks": [
        {
          "type": "note",
          "settings": {
            "title": "Intentional craft",
            "text": "Every piece is designed to feel considered, personal, and quietly luxurious."
          }
        }
      ]
    }
  ]
}
{% endschema %}
