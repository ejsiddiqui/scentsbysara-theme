{%- liquid
  assign margin_px = section.settings.margin
  assign custom_class = section.settings.custom_class | strip
-%}

<section
  id="FullWidthImage-{{ section.id }}"
  class="full-width-image section-block color-{{ section.settings.color_scheme }}{% if custom_class != '' %} {{ custom_class }}{% endif %}"
>
  {%- if section.settings.image != blank -%}
    <div
      class="full-width-image__wrap"
      {% if margin_px != blank %}style="margin-inline: {{ margin_px }}px;"{% endif %}
    >
      {% render 'image',
        image: section.settings.image,
        alt: section.settings.alt_text | default: '',
        class: 'full-width-image__img',
        loading: 'lazy',
        sizes: '100vw'
      %}
    </div>
  {%- else -%}
    <div class="full-width-image__placeholder"{% if margin_px != blank %} style="margin-inline: {{ margin_px }}px;"{% endif %}>
      <span>Select an image in the theme editor</span>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .full-width-image {
    overflow: clip;
  }

  .full-width-image__wrap {
    line-height: 0;
  }

  .full-width-image__img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .full-width-image__placeholder {
    display: grid;
    place-items: center;
    min-height: 200px;
    background: var(--color-secondary-bg);
    border: 1px dashed var(--color-border);
    color: var(--color-muted);
    font-size: var(--text-small);
    letter-spacing: 0.08em;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Full width image",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Image alt text"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Add a class name to target this image with custom CSS."
    },
    {
      "type": "number",
      "id": "margin",
      "label": "Side margin (px)",
      "info": "Horizontal margin applied to each side of the image. Leave blank for none."
    }
  ],
  "presets": [
    {
      "name": "Full width image"
    }
  ]
}
{% endschema %}
