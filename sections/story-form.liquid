<section class="story-form-section section-block color-{{ section.settings.color_scheme }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}">
  <div class="container story-form-section__inner">
    <div class="story-form-section__intro text-center">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}

      <h1 class="font-serif text-h1">{{ section.settings.heading | escape }}</h1>

      {%- if section.settings.description != blank -%}
        <p class="story-form-section__description text-body text-muted">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    {%- form 'contact', id: 'story-submission', class: 'story-form' -%}
      {%- if form.posted_successfully? -%}
        <p class="form-success" role="status">Thank you for sharing your story. We will review it soon.</p>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="form-errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <input type="hidden" name="contact[tags]" value="story-submission">

      <div class="story-form__grid grid-cols-2">
        <div class="form-group">
          <label for="StoryName-{{ section.id }}" class="form-label">YOUR NAME</label>
          <input id="StoryName-{{ section.id }}" type="text" name="contact[name]" class="form-input" required autocomplete="name">
        </div>

        <div class="form-group">
          <label for="StoryEmail-{{ section.id }}" class="form-label">YOUR EMAIL</label>
          <input id="StoryEmail-{{ section.id }}" type="email" name="contact[email]" class="form-input" required autocomplete="email">
        </div>
      </div>

      <div class="form-group">
        <label for="StoryMessage-{{ section.id }}" class="form-label">YOUR STORY</label>
        <textarea
          id="StoryMessage-{{ section.id }}"
          name="contact[body]"
          class="form-input story-form__textarea"
          rows="8"
          required
        ></textarea>
      </div>

      {%- if section.settings.disclaimer != blank -%}
        <p class="story-form__disclaimer text-small text-muted">{{ section.settings.disclaimer | escape }}</p>
      {%- endif -%}

      <div class="story-form__actions text-center">
        <button type="submit" class="btn-hero">SHARE WITH US</button>
      </div>
    {%- endform -%}
  </div>
</section>

{% stylesheet %}
  .story-form-section__inner {
    display: grid;
    gap: var(--space-lg);
  }

  .story-form-section .text-h1 {
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .story-form-section__intro {
    max-width: 48rem;
    margin-inline: auto;
  }

  .story-form-section__description {
    margin-top: 1rem;
    margin-bottom: 3rem;
  }

  .story-form {
    max-width: 52rem;
    margin-inline: auto;
    display: grid;
    gap: 1rem;
  }

  .story-form .form-label {
    font-size: var(--text-micro);
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .story-form .form-input {
    border: 1px solid var(--border-heavy);
    padding: 16px;
  }

  .story-form__grid {
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .story-form__textarea {
    min-height: 14rem;
  }

  .story-form__disclaimer {
    margin: 1.5rem 0 2rem;
    line-height: 1.4;
  }

  .story-form .btn-hero {
    width: 260px;
  }

  @media (max-width: 749px) {
    .story-form__grid {
      grid-template-columns: 1fr;
    }
    
    .story-form .btn-hero {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Story form",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SHARE WITH US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SUBMIT YOUR STORY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Tell us about your moment. We may feature your story as part of our community pages or in upcoming editorials."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "By submitting, you agree that Scents by Sara may publish your story, edited for brevity, across our digital channels."
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Add a custom class to the section element for section-specific CSS overrides."
    }
  ],
  "presets": [
    {
      "name": "Story form"
    }
  ]
}
{% endschema %}
