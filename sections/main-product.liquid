{{ 'section-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign active_media = current_variant.featured_media | default: product.featured_media
  assign active_media_id = active_media.id
  assign has_gallery_media = false
  assign media_count = 0

  for media in product.media
    if media.preview_image != blank
      assign media_count = media_count | plus: 1
      assign has_gallery_media = true
    endif
  endfor

  assign subtitle_text = product.metafields.custom.subtitle | default: product.metafields.custom.subheading | default: product.type | default: section.settings.fallback_subtitle
-%}

<section
  class="product-page-section"
  id="ProductSection-{{ section.id }}"
  data-product-section
>
  <div class="container product-page-main">
    {% render 'breadcrumbs', product: product %}

    <div class="product-mobile-header">
      <div class="product-mobile-header__copy product-mobile-header-copy">
        <h1 class="font-serif product-details__title product-title">{{ product.title | upcase }}</h1>
        <p class="product-details__subtitle subtitle">{{ subtitle_text }}</p>
      </div>
      <div class="product-mobile-header__price">
        {% render 'price', card_product: product, variant: current_variant %}
      </div>
    </div>

    <div class="product-main product-page-grid">
      <div
        class="product-gallery"
        data-product-gallery
        data-product-gallery-count="{{ media_count }}"
        data-initial-media="{{ active_media_id }}"
      >
        <div class="main-image-wrap product-gallery__stage">
          {%- if has_gallery_media -%}
            {%- capture gallery_options -%}
            {
              "type": {{ section.settings.gallery_transition | default: 'fade' | json }},
              "rewind": true,
              "pagination": false,
              "arrows": false,
              "drag": {{ section.settings.gallery_drag | default: true | json }},
              "speed": 400,
              "classes": {},
              "breakpoints": {
                "480": {
                  "arrows": true
                }
              }
            }
            {%- endcapture -%}

            {%- capture thumb_options -%}
            {
              "perPage": 3,
              "gap": 12,
              "rewind": true,
              "pagination": false,
              "arrows": false,
              "isNavigation": true,
              "focus": "center",
              "classes": {},
              "breakpoints": {
                "749": {
                  "gap": 8
                }
              }
            }
            {%- endcapture -%}

            <div
              class="splide product-gallery__viewport"
              data-splide='{{ gallery_options | strip_newlines | strip }}'
              data-splide-sync=".product-gallery__thumbnails"
              aria-label="{{ product.title | escape }} media gallery"
            >
              <div class="splide__track">
                <ul class="splide__list">
                  {%- for media in product.media -%}
                    {%- if media.preview_image != blank -%}
                      {%- liquid
                        assign is_first = false
                        if active_media_id == blank and forloop.first
                          assign is_first = true
                        elsif media.id == active_media_id
                          assign is_first = true
                        endif
                      -%}
                      <li
                        class="splide__slide product-gallery-slide"
                        data-product-gallery-slide
                        data-media-id="{{ media.id }}"
                      >
                        {%- if is_first -%}
                          {%
                            render 'image',
                            image: media.preview_image,
                            alt: media.alt | default: product.title,
                            sizes: '(min-width: 1200px) 52vw, 100vw',
                            widths: '375,540,720,960,1200,1500',
                            loading: 'eager',
                            fetchpriority: 'high',
                            class: 'product-gallery__image'
                          %}
                        {%- else -%}
                          {%
                            render 'image',
                            image: media.preview_image,
                            alt: media.alt | default: product.title,
                            sizes: '(min-width: 1200px) 52vw, 100vw',
                            widths: '375,540,720,960,1200,1500',
                            loading: 'lazy',
                            class: 'product-gallery__image'
                          %}
                        {%- endif -%}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
            </div>

            <button
              class="product-gallery__wishlist wishlist-btn icon-btn"
              type="button"
              aria-label="Add {{ product.title | escape }} to wishlist"
              aria-pressed="false"
            >
              {% render 'icon', name: 'wishlist', size: 20 %}
            </button>
          {%- else -%}
            <div class="product-gallery__placeholder">
              {{ 'product-apparel-1' | placeholder_svg_tag: 'product-gallery__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- if media_count > 1 -%}
          <div
            class="splide product-gallery__thumbnails"
            data-splide='{{ thumb_options | strip_newlines | strip }}'
            data-splide-is-sync
            aria-label="Product image thumbnails"
          >
            <div class="splide__track">
              <ul class="splide__list">
                {%- for media in product.media -%}
                  {%- if media.preview_image != blank -%}
                    <li class="splide__slide product-gallery__thumb" data-media-id="{{ media.id }}">
                      {%
                        render 'image',
                        image: media.preview_image,
                        alt: media.alt | default: product.title,
                        sizes: '282px',
                        widths: '282,420,564,720',
                        loading: 'lazy',
                        class: 'product-gallery__thumb-image'
                      %}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          </div>
        {%- endif -%}
      </div>

      <div class="product-details">
        <header class="product-header-block product-details__header">
          <div class="product-details__meta" aria-live="polite" aria-atomic="true">
            <div class="product-details__heading-copy">
              <h1 class="product-details__title product-title font-serif text-h1">{{ product.title | upcase }}</h1>
              <p class="product-details__subtitle subtitle">{{ subtitle_text }}</p>
            </div>
            <div class="product-details__price-wrap">
              {% render 'price', card_product: product, variant: current_variant %}
            </div>
          </div>
        </header>

        <div class="product-details__controls" aria-label="Product purchase structure">
          {%- assign product_form_id = 'ProductForm-' | append: section.id -%}
          {%- form 'product', product, id: product_form_id, class: 'product-form', data-product-form: '' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

            <variant-picker
              class="product-details__slot"
              data-section="{{ section.id }}"
              data-product-url="{{ product.url }}"
              aria-label="Variant picker"
            >
              {% render 'variant-picker', product: product, section: section %}
            </variant-picker>

            <div class="selector-group selector-group--quantity">
              <div class="selector-label text-sm">QUANTITY</div>
              <div class="add-to-cart-row">
                <quantity-selector class="qty-selector quantity-selector">
                  <button type="button" class="qty-btn" data-action="decrease" aria-label="Decrease quantity">-</button>
                  <input type="number" name="quantity" value="1" min="1" aria-label="Quantity" class="qty-input">
                  <button type="button" class="qty-btn" data-action="increase" aria-label="Increase quantity">+</button>
                </quantity-selector>

                <button
                  type="submit"
                  class="btn-solid btn-add-bag add-to-cart"
                  data-add-to-cart
                  {% unless current_variant.available %}
                    disabled
                  {% endunless %}
                >
                  {%- if current_variant.available -%}
                    ADD TO BAG - {{ current_variant.price | money }}
                  {%- else -%}
                    SOLD OUT
                  {%- endif -%}
                </button>
              </div>
            </div>
          {%- endform -%}

          {%- if section.blocks.size > 0 -%}
            <div class="accordion-wrapper product-accordions">
              {%- for block in section.blocks -%}
                {%- liquid
                  assign accordion_handle = block.settings.title | handleize
                -%}
                {%- if accordion_handle == 'description' -%}
                  {% render 'accordion',
                    title: block.settings.title,
                    content: product.description,
                    open: block.settings.open_by_default,
                    persistent: true,
                    group: section.id,
                    hide_indicator: forloop.first
                  %}
                {%- elsif accordion_handle == 'craft-intention'
                  and product.metafields.custom.craft_intention != blank
                -%}
                  {% render 'accordion',
                    title: block.settings.title,
                    content: product.metafields.custom.craft_intention,
                    open: block.settings.open_by_default,
                    group: section.id,
                    hide_indicator: forloop.first
                  %}
                {%- elsif accordion_handle == 'how-to-use' and product.metafields.custom.how_to_use != blank -%}
                  {% render 'accordion',
                    title: block.settings.title,
                    content: product.metafields.custom.how_to_use,
                    open: block.settings.open_by_default,
                    group: section.id,
                    hide_indicator: forloop.first
                  %}
                {%- elsif accordion_handle == 'dimensions-ingredients'
                  and product.metafields.custom.dimensions_ingredients != blank
                -%}
                  {% render 'accordion',
                    title: block.settings.title,
                    content: product.metafields.custom.dimensions_ingredients,
                    open: block.settings.open_by_default,
                    group: section.id,
                    hide_indicator: forloop.first
                  %}
                {%- else -%}
                  {% render 'accordion',
                    title: block.settings.title,
                    content: block.settings.content,
                    open: block.settings.open_by_default,
                    group: section.id,
                    hide_indicator: forloop.first
                  %}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description summary",
      "default": true
    },
    {
      "type": "text",
      "id": "fallback_subtitle",
      "label": "Fallback subtitle",
      "default": "STRETCH MARK BODY CANDLE"
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "select",
      "id": "gallery_transition",
      "label": "Gallery transition",
      "default": "fade",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" }
      ]
    },
    {
      "type": "checkbox",
      "id": "gallery_drag",
      "label": "Enable swipe / drag",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Main product"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Description"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Fallback content"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ]
}
{% endschema %}
