{%- liquid
  assign text_style = section.settings.text_style | default: 'static'
-%}

<section
  id="AnnouncementBar-{{ section.id }}"
  class="announcement-bar color-{{ section.settings.color_scheme }}"
  data-text-style="{{ text_style }}"
  aria-label="Site announcements"
>
  <div class="announcement-bar__inner container">
    <div class="announcement-bar__message">
      {%- if section.blocks.size > 0 -%}
        {%- if text_style == 'marquee' -%}
          <div class="announcement-bar__marquee" aria-label="Site announcements">
            <div class="announcement-bar__track">
              {%- for repeat in (1..2) -%}
                <div class="announcement-bar__set"{% if repeat == 2 %} aria-hidden="true"{% endif %}>
                  {%- for block in section.blocks -%}
                    <div class="announcement-bar__item" {{ block.shopify_attributes }}>
                      {%- if block.settings.link != blank -%}
                        <a class="announcement-bar__link" href="{{ block.settings.link }}">
                          {{ block.settings.text | escape }}
                        </a>
                      {%- else -%}
                        <span class="announcement-bar__text">{{ block.settings.text | escape }}</span>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <ul class="announcement-bar__list" role="list">
            {%- for block in section.blocks -%}
              <li class="announcement-bar__item" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a class="announcement-bar__link" href="{{ block.settings.link }}">
                    {{ block.settings.text | escape }}
                  </a>
                {%- else -%}
                  <span class="announcement-bar__text">{{ block.settings.text | escape }}</span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      {%- elsif request.design_mode -%}
        <p class="announcement-bar__placeholder">Add an announcement block in the theme editor.</p>
      {%- endif -%}
    </div>

    <div class="announcement-bar__localization">
      {% render 'localization-form' %}
    </div>
  </div>
</section>

{% style %}
  #AnnouncementBar-{{ section.id }} {
    background: var(--color-background);
    color: var(--color-foreground);
    overflow: hidden;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    min-height: var(--announcement-height);
    padding-top: var(--space-sm);
    padding-bottom: var(--space-sm);
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__message {
    flex: 1 1 auto;
    min-width: 0;
    text-align: center;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__list,
  #AnnouncementBar-{{ section.id }} .announcement-bar__set {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-small);
    font-weight: 500;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__item + .announcement-bar__item::before {
    content: "•";
    opacity: 0.6;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__link {
    color: inherit;
    text-decoration: none;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__marquee {
    overflow: hidden;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__track {
    display: flex;
    width: max-content;
    animation: announcement-marquee-{{ section.id }} 18s linear infinite;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__set {
    flex: 0 0 auto;
    padding-right: var(--space-md);
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__placeholder {
    margin: 0;
    font-size: var(--text-xsmall, 11px);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.72;
  }

  #AnnouncementBar-{{ section.id }} .announcement-bar__localization {
    display: none;
  }

  @keyframes announcement-marquee-{{ section.id }} {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 767px) {
    #AnnouncementBar-{{ section.id }} .announcement-bar__inner {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-xs);
      text-align: center;
    }

    #AnnouncementBar-{{ section.id }} .announcement-bar__message,
    #AnnouncementBar-{{ section.id }} .announcement-bar__localization {
      justify-content: center;
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #AnnouncementBar-{{ section.id }} .announcement-bar__track {
      animation: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "text_style",
      "label": "Text style",
      "options": [
        {
          "value": "static",
          "label": "Static"
        },
        {
          "value": "marquee",
          "label": "Marquee"
        }
      ],
      "default": "static"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Launching March 2026 - join the waiting list for early access"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
