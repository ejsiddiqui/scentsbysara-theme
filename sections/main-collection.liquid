{{ 'section-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_sort = collection.sort_by | default: collection.default_sort_by
-%}

{%- paginate collection.products by section.settings.products_per_page -%}
  <facet-filters
    class="collection-page color-{{ section.settings.color_scheme }}"
    data-collection-section
    data-section="{{ section.id }}"
    data-collection-url="{{ collection.url }}"
  >
    {%- if collection.image or section.settings.hero_image != blank -%}
      {%- liquid
        assign hero_img = section.settings.hero_image | default: collection.image
      -%}
      <div class="collection-fullbleed-hero">
        {% render 'image',
          image: hero_img,
          class: 'collection-fullbleed-hero__bg',
          alt: collection.title,
          widths: '750,1100,1500,2000',
          sizes: '100vw',
          loading: 'eager'
        %}
        <div class="collection-fullbleed-hero__overlay"></div>
        <div class="container collection-fullbleed-hero__content">
          <h1 class="font-serif collection-fullbleed-hero__title">{{ collection.title | upcase }}</h1>
          {%- if collection.description != blank -%}
            <p class="collection-fullbleed-hero__desc">{{ collection.description | strip_html | truncatewords: 30 }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <section class="collection-page__inner section-block">
      <div class="container shop-page-shell">
        {%- unless collection.image or section.settings.hero_image != blank -%}
          <header class="collection-hero shop-hero">
            <h1 class="font-serif text-h1">{{ collection.title | upcase }}</h1>

            {%- if collection.description != blank -%}
              <div class="collection-hero__description text-body rte">
                {{ collection.description }}
              </div>
            {%- endif -%}
          </header>
        {%- endunless -%}

        <form class="collection-toolbar filter-toolbar" data-facets-form>
          <div class="collection-toolbar__primary">
            {%- if section.settings.enable_filtering -%}
              <button
                class="filter-btn collection-toolbar__toggle"
                type="button"
                data-facets-toggle
                aria-expanded="false"
                aria-controls="CollectionFiltersPanel-{{ section.id }}"
              >
                <span class="filter-btn-label filter-btn-label-desktop">FILTER</span>
                <svg class="filter-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                  <line x1="4" y1="21" x2="4" y2="14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="4" y1="10" x2="4" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="12" y1="21" x2="12" y2="12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="12" y1="8" x2="12" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="20" y1="21" x2="20" y2="16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="20" y1="12" x2="20" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="1" y1="14" x2="7" y2="14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="9" y1="8" x2="15" y2="8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                  <line x1="17" y1="16" x2="23" y2="16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></line>
                </svg>
                <span class="filter-btn-label filter-btn-label-mobile">SORT &amp; FILTER</span>
              </button>
            {%- endif -%}

            {%- if section.settings.enable_sorting -%}
              <div class="sort-dropdown">
                <label for="CollectionSort-{{ section.id }}" class="sort-label">SORT BY:</label>
                <select id="CollectionSort-{{ section.id }}" name="sort_by" class="sort-select" data-sort-select>
                  {%- for option in collection.sort_options -%}
                    <option value="{{ option.value }}"{% if option.value == current_sort %} selected{% endif %}>
                      {{ option.name }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endif -%}
          </div>

          <p class="mobile-item-count collection-toolbar__count" data-product-count aria-live="polite">
            {{ collection.products_count }} ITEMS
          </p>
        </form>

        {%- if section.settings.enable_filtering -%}
          <div
            id="CollectionFiltersPanel-{{ section.id }}"
            class="collection-filters"
            data-facets-panel
            hidden
          >
            <div class="collection-filters__scrim" data-facets-close></div>
            <div class="collection-filters__dialog" role="dialog" aria-modal="true" aria-labelledby="CollectionFiltersHeading-{{ section.id }}">
              <div class="collection-filters__header">
                <h2 id="CollectionFiltersHeading-{{ section.id }}" class="font-serif text-h4">FILTERS</h2>
                <button type="button" class="icon-btn" data-facets-close aria-label="Close filters">
                  {% render 'icon', name: 'close', size: 18 %}
                </button>
              </div>

              <div class="collection-filters__body">
                {%- for filter in collection.filters -%}
                  <details class="filter-group" open>
                    <summary class="filter-group__summary">
                      <span>{{ filter.label | escape }}</span>
                      {% render 'icon', name: 'plus', size: 16 %}
                    </summary>

                    <div class="filter-group__body">
                      {%- case filter.type -%}
                        {%- when 'list', 'boolean' -%}
                          <ul class="filter-group__list" role="list">
                            {%- for value in filter.values -%}
                              <li class="filter-group__item">
                                <label class="filter-group__option">
                                  <input
                                    type="checkbox"
                                    name="{{ value.param_name }}"
                                    value="{{ value.value }}"
                                    {% if value.active %}checked{% endif %}
                                    {% if value.count == 0 and value.active == false %}disabled{% endif %}
                                  >
                                  <span>{{ value.label }} ({{ value.count }})</span>
                                </label>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- when 'price_range' -%}
                          <div class="filter-group__price">
                            <label class="filter-group__price-field">
                              <span>Min</span>
                              <input
                                type="number"
                                name="{{ filter.min_value.param_name }}"
                                value="{{ filter.min_value.value | default: '' }}"
                                min="0"
                                inputmode="numeric"
                              >
                            </label>
                            <label class="filter-group__price-field">
                              <span>Max</span>
                              <input
                                type="number"
                                name="{{ filter.max_value.param_name }}"
                                value="{{ filter.max_value.value | default: '' }}"
                                min="0"
                                inputmode="numeric"
                              >
                            </label>
                          </div>
                      {%- endcase -%}
                    </div>
                  </details>
                {%- endfor -%}
              </div>

              <div class="collection-filters__footer">
                <a href="{{ collection.url }}" class="btn-outline collection-filters__clear" data-clear-filters>
                  CLEAR ALL
                </a>
                <button type="submit" class="btn-solid collection-filters__apply">
                  APPLY FILTERS
                </button>
              </div>
            </div>
          </div>
        {%- endif -%}

        <div class="shop-products">
          <div
            id="ProductGrid-{{ section.id }}"
            class="product-grid grid-cols-4 collection-grid"
            data-product-grid
            style="--collection-columns: {{ section.settings.columns_desktop }};"
          >
            {%- for product in collection.products -%}
              {% render 'product-card',
                product: product,
                card_layout: 'shop',
                show_secondary_image: true,
                show_swatches: true,
                show_quick_add: false
              %}
            {%- else -%}
              <div class="collection-grid__empty" role="status">
                No products match your current filters.
              </div>
            {%- endfor -%}
          </div>
        </div>

        {% render 'pagination', paginate: paginate %}
      </div>
    </section>
  </facet-filters>
{%- endpaginate -%}

{% stylesheet %}
  .collection-fullbleed-hero {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 35vw, 480px);
    display: flex;
    align-items: flex-end;
  }

  .collection-fullbleed-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-fullbleed-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
  }

  .collection-fullbleed-hero__content {
    position: relative;
    z-index: 1;
    padding-bottom: clamp(2rem, 4vw, 4rem);
    padding-top: clamp(2rem, 4vw, 4rem);
    display: grid;
    gap: 0.75rem;
  }

  .collection-fullbleed-hero__title {
    color: #F9F6F2;
    font-size: clamp(2rem, 4vw + 1rem, var(--font-size-h1));
    letter-spacing: 0.12em;
    line-height: 1;
  }

  .collection-fullbleed-hero__desc {
    color: rgba(249, 246, 242, 0.85);
    max-width: 50rem;
    font-size: var(--text-body);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Main collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image override"
    }
  ]
}
{% endschema %}
