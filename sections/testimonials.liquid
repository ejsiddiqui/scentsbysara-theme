{%- liquid
  assign section_heading = section.settings.heading | default: 'CUSTOMER TESTIMONIALS'
  assign star_count = section.settings.star_count | default: 5
  assign transition_type = section.settings.transition_type | default: 'fade'
  assign autoplay = section.settings.autoplay | default: false
  assign interval = section.settings.interval | default: 6
  assign drag_enabled = section.settings.drag | default: true
-%}

{%- capture splide_options -%}
{
  "type": {{ transition_type | json }},
  "rewind": true,
  "autoplay": {{ autoplay | json }},
  "interval": {{ interval | times: 1000 }},
  "pauseOnHover": true,
  "pauseOnFocus": true,
  "speed": 500,
  "drag": {{ drag_enabled | json }},
  "arrows": false,
  "pagination": true,
  "classes": {
    "pagination": "splide__pagination testimonials-dots",
    "page": "splide__pagination__page testimonials-dot"
  }
}
{%- endcapture -%}

<section
  id="Testimonials-{{ section.id }}"
  class="testimonials-section section-block bg-primary text-center color-{{ section.settings.color_scheme }}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class | escape }}{% endif %}"
>
  {{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

  <div class="container">
    <header class="testimonials-section__header">
      <h2 class="section-title font-sans text-h3">{{ section_heading | escape }}</h2>

      {%- if section.settings.show_stars -%}
        <div class="testimonials-section__stars" aria-hidden="true">
          {%- for i in (1..star_count) -%}
            <img src="{{ 'star_filled.svg' | asset_url }}" alt="" width="24" height="24">
          {%- endfor -%}
          {%- assign empty_stars = 5 | minus: star_count -%}
          {%- if empty_stars > 0 -%}
            {%- for i in (1..empty_stars) -%}
              <img src="{{ 'star_empty.svg' | asset_url }}" alt="" width="24" height="24">
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </header>

    <div
      class="splide testimonials-section__slider"
      data-splide='{{ splide_options }}'
      aria-label="{{ section.settings.aria_label | default: section_heading | escape }}"
    >
      <div class="splide__track">
        <ul class="splide__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'testimonial' -%}
              <li
                class="splide__slide testimonial-slide"
                {{ block.shopify_attributes }}
              >
                <article class="testimonial-content">
                  <p class="testimonial-text">{{ block.settings.quote | escape | newline_to_br }}</p>
                  <p class="testimonial-author">{{ block.settings.author | escape }}</p>
                </article>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</section>

{% style %}
  @media screen and (max-width: 480px) {
    #Testimonials-{{ section.id }} .section-title {
      font-size: var(--text-small);
      letter-spacing: 0.08em;
    }

    #Testimonials-{{ section.id }} .testimonials-section__stars {
      font-size: 1rem;
      gap: 0.2rem;
    }

    #Testimonials-{{ section.id }} .testimonial-text {
      font-size: var(--text-body);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CUSTOMER TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Carousel accessibility label",
      "default": "Customer testimonials"
    },
    {
      "type": "header",
      "content": "Slider behaviour"
    },
    {
      "type": "select",
      "id": "transition_type",
      "label": "Transition type",
      "default": "fade",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" },
        { "value": "loop", "label": "Loop (infinite)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "interval",
      "label": "Autoplay interval",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "drag",
      "label": "Enable swipe / drag",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show stars",
      "default": true
    },
    {
      "type": "range",
      "id": "star_count",
      "label": "Star count",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class",
      "info": "Add a custom class to the section element for section-specific CSS overrides."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "I knew that the candles looked amazing, but I did not expect them to smell as amazing too! Scents By Sara really gives the full package. I am hesitating to light mine because then the magic ends."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "EUNICE YUMBA"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "I knew that the candles looked amazing, but I did not expect them to smell as amazing too! Scents By Sara really gives the full package. I am hesitating to light mine because then the magic ends.",
            "author": "EUNICE YUMBA"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Absolutely stunning pieces that instantly elevated my living room. The scent throw even when unlit is incredible. A true work of art.",
            "author": "SARAH JENNINGS"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The attention to detail is unmatched. I gifted this to my sister and she was brought to tears by the beautiful intention behind the sculpted design.",
            "author": "MICHELLE D."
          }
        }
      ]
    }
  ]
}
{% endschema %}
