{%- liquid
  assign section_heading = section.settings.heading | default: 'CUSTOMER TESTIMONIALS'
  assign star_count = section.settings.star_count | default: 5
-%}

<section
  id="Testimonials-{{ section.id }}"
  class="testimonials-section section-block bg-primary text-center color-{{ section.settings.color_scheme }}"
>
  {{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

  <div class="container">
    <header class="testimonials-section__header">
      <h2 class="section-title font-serif text-h1">{{ section_heading | escape }}</h2>

      {%- if section.settings.show_stars -%}
      <div class="testimonials-section__stars" aria-hidden="true">
        {%- for i in (1..star_count) -%}
          <span class="testimonials-section__star">★</span>
        {%- endfor -%}
      </div>
      {%- endif -%}
    </header>

    <slideshow-component
      class="testimonials-section__slider testimonials-slider"
      data-autoplay="false"
      data-interval="6"
      aria-roledescription="carousel"
      aria-label="{{ section.settings.aria_label | default: section_heading | escape }}"
    >
      <div class="testimonials-section__slides">
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            <article
              id="Testimonial-{{ section.id }}-{{ forloop.index0 }}"
              class="testimonial-slide{% if forloop.first %} is-active{% endif %}"
              data-slide
              role="tabpanel"
              aria-labelledby="TestimonialTab-{{ section.id }}-{{ forloop.index0 }}"
              aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
              tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="testimonial-content">
                <p class="testimonial-text">{{ block.settings.quote | escape | newline_to_br }}</p>
                <p class="testimonial-author">{{ block.settings.author | escape }}</p>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="slider-dots testimonials-section__dots" role="tablist" aria-label="Testimonial navigation">
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            <button
              type="button"
              class="dot slideshow-dot{% if forloop.first %} is-active{% endif %}"
              id="TestimonialTab-{{ section.id }}-{{ forloop.index0 }}"
              role="tab"
              data-slide-index="{{ forloop.index0 }}"
              aria-controls="Testimonial-{{ section.id }}-{{ forloop.index0 }}"
              aria-label="Show testimonial {{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            ></button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </slideshow-component>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CUSTOMER TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Carousel accessibility label",
      "default": "Customer testimonials"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show stars",
      "default": true
    },
    {
      "type": "range",
      "id": "star_count",
      "label": "Star count",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "I knew that the candles looked amazing, but I did not expect them to smell as amazing too! Scents By Sara really gives the full package. I am hesitating to light mine because then the magic ends."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "EUNICE YUMBA"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "I knew that the candles looked amazing, but I did not expect them to smell as amazing too! Scents By Sara really gives the full package. I am hesitating to light mine because then the magic ends.",
            "author": "EUNICE YUMBA"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Absolutely stunning pieces that instantly elevated my living room. The scent throw even when unlit is incredible. A true work of art.",
            "author": "SARAH JENNINGS"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "The attention to detail is unmatched. I gifted this to my sister and she was brought to tears by the beautiful intention behind the sculpted design.",
            "author": "MICHELLE D."
          }
        }
      ]
    }
  ]
}
{% endschema %}
