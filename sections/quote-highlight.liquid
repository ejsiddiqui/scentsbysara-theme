<section class="quote-highlight section-block color-{{ section.settings.color_scheme }}">
  <div class="container quote-highlight__inner quote-highlight__inner--{{ section.settings.text_alignment }}">
    <blockquote class="quote-highlight__quote font-serif">{{ section.settings.quote | escape }}</blockquote>

    {%- if section.settings.attribution != blank -%}
      <p class="quote-highlight__attribution text-micro text-muted">{{ section.settings.attribution | escape }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .quote-highlight__inner {
    padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 8vw, 10rem);
  }

  .quote-highlight__inner--center {
    text-align: center;
  }

  .quote-highlight__inner--left {
    text-align: left;
  }

  .quote-highlight__quote {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    line-height: 1.25;
    font-style: italic;
    letter-spacing: 0.01em;
  }

  .quote-highlight__attribution {
    margin-top: 1.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Quote highlight",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "Scents by Sara was built on the stories of real women. We invite you to be part of the narrative."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Attribution",
      "default": "Scents by Sara"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Quote highlight"
    }
  ]
}
{% endschema %}
