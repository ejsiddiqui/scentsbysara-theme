<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title | default: shop.name }}</title>
    {% render 'design-tokens' %}
    {% render 'color-schemes' %}
    {{ 'rl-limo.css' | asset_url | stylesheet_tag }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {% render 'meta-tags' %}
    {{ content_for_header }}
  </head>

  <body class="template-password color-scheme-1">
    <main id="MainContent" class="page-wrapper">
      {{ content_for_layout }}
    </main>
  </body>
</html>
