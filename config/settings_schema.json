[
  {
    "name": "theme_info",
    "theme_name": "Scents by Sara",
    "theme_author": "Epyc Digital",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://github.com/ejsiddiqui/scentsbysara-html",
    "theme_support_url": "https://github.com/ejsiddiqui/scentsbysara-html/issues"
  },
  {
    "name": "t:settings_schema.brand.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "t:settings_schema.brand.settings.logo.label"
      },
      {
        "type": "image_picker",
        "id": "logo_inverse",
        "label": "t:settings_schema.brand.settings.logo_inverse.label"
      },
      {
        "type": "image_picker",
        "id": "logo_mobile",
        "label": "t:settings_schema.brand.settings.logo_mobile.label"
      },
      {
        "type": "range",
        "id": "logo_height",
        "min": 20,
        "max": 80,
        "step": 1,
        "unit": "px",
        "label": "t:settings_schema.brand.settings.logo_height.label",
        "default": 40
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings_schema.brand.settings.favicon.label"
      }
    ]
  },
  {
    "name": "t:settings_schema.colour_schemes.name",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "t:settings_schema.colour_schemes.settings.background.label",
            "default": "#F9F6F2"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "t:settings_schema.colour_schemes.settings.background_gradient.label",
            "info": "t:settings_schema.colour_schemes.settings.background_gradient.info"
          },
          {
            "type": "color",
            "id": "text",
            "label": "t:settings_schema.colour_schemes.settings.text.label",
            "default": "#3F3229"
          },
          {
            "type": "color",
            "id": "muted",
            "label": "t:settings_schema.colour_schemes.settings.muted.label",
            "default": "#A39382"
          },
          {
            "type": "color",
            "id": "border",
            "label": "t:settings_schema.colour_schemes.settings.border.label",
            "default": "#CEC5B8"
          },
          {
            "type": "color",
            "id": "secondary_bg",
            "label": "t:settings_schema.colour_schemes.settings.secondary_bg.label",
            "default": "#E7E3DC"
          },
          {
            "type": "color",
            "id": "accent",
            "label": "t:settings_schema.colour_schemes.settings.accent.label",
            "default": "#3F3229"
          },
          {
            "type": "color",
            "id": "button",
            "label": "t:settings_schema.colour_schemes.settings.button.label",
            "default": "#3F3229"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "t:settings_schema.colour_schemes.settings.button_label.label",
            "default": "#F9F6F2"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "t:settings_schema.colour_schemes.settings.secondary_button_label.label",
            "default": "#3F3229"
          },
          {
            "type": "color",
            "id": "shadow",
            "label": "t:settings_schema.colour_schemes.settings.shadow.label",
            "default": "#3F3229"
          },
          {
            "type": "color",
            "id": "success",
            "label": "t:settings_schema.colour_schemes.settings.success.label",
            "default": "#2d6a4f"
          },
          {
            "type": "color",
            "id": "error",
            "label": "t:settings_schema.colour_schemes.settings.error.label",
            "default": "#8b2e2e"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "accent",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "secondary_bg",
          "on_secondary_button": "secondary_button_label",
          "secondary_button_border": "border"
        }
      }
    ]
  },
  {
    "name": "t:settings_schema.typography.name",
